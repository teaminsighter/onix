<% var currentPage = 'analytics'; %>
<%- include('partials/sidebar', { user, active: 'analytics' }) %>

<main class="main">
    <div class="page-header">
        <div>
            <h1 class="page-title">Analytics</h1>
        </div>
        <%- include('partials/date-picker') %>
    </div>

    <!-- Quick Stats -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-label">Avg Response Time</div>
            <div class="stat-value"><%= quickStats.avgResponseTime > 0 ? quickStats.avgResponseTime.toFixed(1) + ' hrs' : 'N/A' %></div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Lead-to-Meeting Rate</div>
            <div class="stat-value accent"><%= quickStats.leadToMeetingRate %>%</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Meeting-to-Close Rate</div>
            <div class="stat-value"><%= quickStats.meetingToCloseRate %>%</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Avg Deal Size</div>
            <div class="stat-value" style="color: var(--success);"><%= quickStats.avgDealSize > 0 ? '$' + Number(quickStats.avgDealSize).toLocaleString() : 'N/A' %></div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="charts-grid">
        <!-- Lead Sources Pie -->
        <div class="card chart-card">
            <div class="card-header">
                <h3 class="card-title">Lead Sources</h3>
            </div>
            <div class="chart-container" id="sourcesChart"></div>
        </div>

        <!-- Conversion Funnel -->
        <div class="card chart-card">
            <div class="card-header">
                <h3 class="card-title">Conversion Funnel</h3>
            </div>
            <div id="funnelChart"></div>
        </div>
    </div>

    <!-- Lead Trends -->
    <div class="card" style="margin-bottom: 1.5rem;">
        <div class="card-header">
            <h3 class="card-title">Lead Trends</h3>
            <div style="display:flex;gap:0.25rem;">
                <button class="btn btn-sm btn-secondary" data-period="daily" onclick="loadTrends('daily', this)">Daily</button>
                <button class="btn btn-sm btn-secondary" data-period="weekly" onclick="loadTrends('weekly', this)">Weekly</button>
                <button class="btn btn-sm btn-primary" data-period="monthly" onclick="loadTrends('monthly', this)">Monthly</button>
            </div>
        </div>
        <div class="chart-container" id="trendsChart" style="min-height: 260px;"></div>
    </div>

    <!-- Source Performance Table -->
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Source Performance</h3>
            <a href="/api/settings/export/leads" class="btn btn-secondary btn-sm">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                    <polyline points="7 10 12 15 17 10"/>
                    <line x1="12" y1="15" x2="12" y2="3"/>
                </svg>
                Export CSV
            </a>
        </div>
        <% if (sourcePerformance.length === 0) { %>
            <div class="empty-state"><p>No lead data yet. Sources will appear here as leads come in.</p></div>
        <% } else { %>
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Source</th>
                        <th>Leads</th>
                        <th>Contacted</th>
                        <th>Scheduled</th>
                        <th>Converted</th>
                        <th>Conversion Rate</th>
                    </tr>
                </thead>
                <tbody>
                    <% sourcePerformance.forEach(function(source) { %>
                        <tr>
                            <td style="font-weight: 500; text-transform: capitalize;"><%= source.source || 'unknown' %></td>
                            <td><%= source.leads %></td>
                            <td><%= source.contacted %></td>
                            <td><%= source.scheduled %></td>
                            <td><%= source.converted %></td>
                            <td>
                                <span style="color: <%= source.conversion_rate >= 20 ? 'var(--success)' : source.conversion_rate >= 10 ? 'var(--accent)' : 'var(--warning)' %>; font-weight: 600;">
                                    <%= source.conversion_rate %>%
                                </span>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
        <% } %>
    </div>
</main>

<%- include('partials/charts') %>
<%- include('partials/modals') %>

<script>
document.addEventListener('DOMContentLoaded', function() {
    var sourcesData = <%- JSON.stringify(chartData.leadSources) %>;
    var funnelData = <%- JSON.stringify(chartData.conversionFunnel) %>;
    var trendsData = <%- JSON.stringify(chartData.leadsOverTime) %>;

    if (sourcesData.data.length > 0) renderPieChart('sourcesChart', sourcesData, { size: 140, donut: true });
    else document.getElementById('sourcesChart').innerHTML = '<div class="empty-state"><p>No data</p></div>';

    if (funnelData.data.some(function(d) { return d > 0; })) renderHorizontalBarChart('funnelChart', funnelData);
    else document.getElementById('funnelChart').innerHTML = '<div class="empty-state"><p>No data</p></div>';

    if (trendsData.data.length > 0) renderLineChart('trendsChart', trendsData, { height: 260 });
    else document.getElementById('trendsChart').innerHTML = '<div class="empty-state"><p>No data</p></div>';
});

function loadTrends(period, btn) {
    // Update active button
    btn.parentElement.querySelectorAll('.btn').forEach(function(b) {
        b.className = 'btn btn-sm btn-secondary';
    });
    btn.className = 'btn btn-sm btn-primary';

    fetch('/api/settings/analytics/trends?period=' + period)
        .then(function(r) { return r.json(); })
        .then(function(data) {
            var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
            var chartData = {
                labels: data.map(function(r) {
                    if (period === 'monthly') {
                        var parts = r.period.split('-');
                        return months[parseInt(parts[1]) - 1] || r.period;
                    }
                    return r.period;
                }),
                data: data.map(function(r) { return r.count; })
            };
            document.getElementById('trendsChart').innerHTML = '';
            if (chartData.data.length > 0) renderLineChart('trendsChart', chartData, { height: 260 });
            else document.getElementById('trendsChart').innerHTML = '<div class="empty-state"><p>No data for this period</p></div>';
        });
}
</script>
