<%- include('partials/sidebar', { user, active: 'analytics' }) %>

<main class="main">
    <div class="page-header">
        <h1 class="page-title">Analytics</h1>
        <div class="header-actions">
            <div style="display: flex; gap: 0.5rem; align-items: center;">
                <input type="date" class="form-input" value="2026-03-06" style="width: auto; padding: 0.5rem 0.75rem;">
                <span style="color: var(--gray);">to</span>
                <input type="date" class="form-input" value="2026-04-06" style="width: auto; padding: 0.5rem 0.75rem;">
                <button class="btn btn-secondary">Apply</button>
            </div>
        </div>
    </div>

    <!-- Visitor Stats Placeholder -->
    <div class="card" style="margin-bottom: 1.5rem;">
        <div class="card-header">
            <h3 class="card-title">Website Visitors</h3>
            <span class="badge badge-warning">Google Analytics Not Connected</span>
        </div>
        <div class="empty-state" style="padding: 3rem;">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--gray)" stroke-width="2">
                <path d="M18 20V10M12 20V4M6 20v-6"/>
            </svg>
            <p style="margin: 1rem 0;">Connect Google Analytics to see visitor data</p>
            <p style="color: var(--gray); font-size: 0.9rem; margin-bottom: 1rem;">
                Track page views, sessions, bounce rate, and more
            </p>
            <a href="/settings" class="btn btn-primary">Connect Google Analytics</a>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="charts-grid">
        <!-- Lead Sources -->
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Lead Sources</h3>
            </div>
            <div class="chart-container" id="sourcesChart"></div>
        </div>

        <!-- Conversion Funnel -->
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Conversion Funnel</h3>
            </div>
            <div id="funnelChart"></div>
        </div>
    </div>

    <!-- Lead Trends -->
    <div class="card" style="margin-bottom: 1.5rem;">
        <div class="card-header">
            <h3 class="card-title">Lead Trends</h3>
            <div class="view-toggle">
                <button class="btn btn-sm btn-secondary active" data-period="daily">Daily</button>
                <button class="btn btn-sm btn-secondary" data-period="weekly">Weekly</button>
                <button class="btn btn-sm btn-secondary" data-period="monthly">Monthly</button>
            </div>
        </div>
        <div class="chart-container" id="trendsChart" style="height: 280px;"></div>
    </div>

    <!-- Source Performance Table -->
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Source Performance</h3>
            <button class="btn btn-secondary btn-sm">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                    <polyline points="7 10 12 15 17 10"/>
                    <line x1="12" y1="15" x2="12" y2="3"/>
                </svg>
                Export CSV
            </button>
        </div>
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Source</th>
                        <th>Leads</th>
                        <th>Contacted</th>
                        <th>Scheduled</th>
                        <th>Converted</th>
                        <th>Conversion Rate</th>
                        <th>Trend</th>
                    </tr>
                </thead>
                <tbody>
                    <% sourcePerformance.forEach(source => { %>
                        <tr>
                            <td style="font-weight: 500;"><%= source.source %></td>
                            <td><%= source.leads %></td>
                            <td><%= source.contacted %></td>
                            <td><%= source.scheduled %></td>
                            <td><%= source.converted %></td>
                            <td>
                                <span style="color: <%= source.conversion_rate >= 23 ? 'var(--success)' : source.conversion_rate >= 20 ? 'var(--accent)' : 'var(--warning)' %>; font-weight: 600;">
                                    <%= source.conversion_rate %>%
                                </span>
                            </td>
                            <td>
                                <div id="sparkline-<%= source.source.toLowerCase() %>" style="width: 80px; height: 24px;"></div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="stats-grid" style="margin-top: 1.5rem;">
        <div class="stat-card">
            <div class="stat-label">Average Response Time</div>
            <div class="stat-value">2.4 hrs</div>
            <div style="font-size: 0.85rem; color: var(--success); margin-top: 0.25rem;">
                <span class="stat-trend positive">-15%</span> vs last month
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Lead-to-Meeting Rate</div>
            <div class="stat-value accent">36%</div>
            <div style="font-size: 0.85rem; color: var(--success); margin-top: 0.25rem;">
                <span class="stat-trend positive">+4%</span> vs last month
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Meeting-to-Close Rate</div>
            <div class="stat-value">65%</div>
            <div style="font-size: 0.85rem; color: var(--gray); margin-top: 0.25rem;">
                <span>No change</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Avg. Deal Size</div>
            <div class="stat-value" style="color: var(--success);">$8,750</div>
            <div style="font-size: 0.85rem; color: var(--success); margin-top: 0.25rem;">
                <span class="stat-trend positive">+12%</span> vs last month
            </div>
        </div>
    </div>
</main>

<%- include('partials/charts') %>
<%- include('partials/modals') %>

<script>
// Initialize charts
document.addEventListener('DOMContentLoaded', function() {
    renderPieChart('sourcesChart', <%= JSON.stringify(chartData.leadSources) %>, { size: 140, donut: true });
    renderHorizontalBarChart('funnelChart', <%= JSON.stringify(chartData.conversionFunnel) %>);
    renderLineChart('trendsChart', <%= JSON.stringify(chartData.leadsOverTime) %>, { height: 260 });

    // Render sparklines
    const sparklineData = {
        website: [12, 15, 18, 14, 22, 25, 20],
        facebook: [8, 10, 12, 9, 14, 11, 13],
        google: [6, 8, 7, 9, 10, 8, 11],
        linkedin: [3, 4, 5, 4, 6, 5, 7],
        referral: [2, 1, 3, 2, 4, 3, 2]
    };

    Object.keys(sparklineData).forEach(source => {
        renderSparkline(`sparkline-${source}`, sparklineData[source], { width: 80, height: 24 });
    });
});

// Period toggle
document.querySelectorAll('.view-toggle .btn').forEach(btn => {
    btn.addEventListener('click', () => {
        document.querySelectorAll('.view-toggle .btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        const period = btn.dataset.period;
        console.log('Switch to:', period);
        // In real implementation, would re-render chart with different data
    });
});
</script>
