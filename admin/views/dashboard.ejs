<%- include('partials/sidebar', { user, active: 'dashboard' }) %>

<main class="main">
    <div class="page-header">
        <div>
            <h1 class="page-title">Dashboard</h1>
            <span style="color: var(--gray);">Welcome back, <%= user.username %></span>
        </div>
        <div class="date-filter-container">
            <button class="date-filter-btn" id="dateFilterBtn" onclick="toggleDatePicker()">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                    <line x1="16" y1="2" x2="16" y2="6"/>
                    <line x1="8" y1="2" x2="8" y2="6"/>
                    <line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
                <span id="dateFilterLabel"><%= typeof dateRange !== 'undefined' && dateRange.label ? dateRange.label : 'All time' %></span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="6 9 12 15 18 9"/>
                </svg>
            </button>
            <div class="date-picker-dropdown" id="datePicker">
                <div class="date-picker-layout">
                    <div class="date-picker-presets">
                        <div class="preset-item" data-preset="today">Today</div>
                        <div class="preset-item" data-preset="yesterday">Yesterday</div>
                        <div class="preset-item" data-preset="this_week">This week (Mon – Today)</div>
                        <div class="preset-item" data-preset="last_7_days">Last 7 days</div>
                        <div class="preset-item" data-preset="last_week">Last week (Mon – Sun)</div>
                        <div class="preset-item" data-preset="last_14_days">Last 14 days</div>
                        <div class="preset-item" data-preset="this_month">This month</div>
                        <div class="preset-item" data-preset="last_30_days">Last 30 days</div>
                        <div class="preset-item" data-preset="last_month">Last month</div>
                        <div class="preset-item active" data-preset="all_time">All time</div>
                        <div class="preset-divider"></div>
                        <div class="preset-custom">
                            <input type="number" id="customDays" value="30" min="1" max="365" class="custom-days-input">
                            <span>days to today</span>
                        </div>
                    </div>
                    <div class="date-picker-calendar">
                        <div class="date-range-display">
                            <span class="date-range-dot"></span>
                            <span>DATE RANGE</span>
                        </div>
                        <div class="date-range-inputs">
                            <input type="date" id="dateFrom" class="date-input">
                            <span>to</span>
                            <input type="date" id="dateTo" class="date-input">
                        </div>
                        <div class="calendar-container" id="calendarContainer"></div>
                    </div>
                </div>
                <div class="date-picker-actions">
                    <button class="btn btn-secondary" onclick="closeDatePicker()">Cancel</button>
                    <button class="btn btn-primary" onclick="applyDateFilter()">Apply</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Overview Stats Grid -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-label">Total Leads</span>
                <span class="stat-trend positive"><%= stats.leads.change %></span>
            </div>
            <div class="stat-value accent"><%= stats.leads.total %></div>
        </div>
        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-label">Conversion Rate</span>
                <span class="stat-trend positive"><%= stats.conversion.change %></span>
            </div>
            <div class="stat-value"><%= stats.conversion.rate %>%</div>
        </div>
        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-label">Revenue</span>
                <span class="stat-trend positive"><%= stats.revenue.change %></span>
            </div>
            <div class="stat-value" style="color: var(--success);">$<%= stats.revenue.total.toLocaleString() %></div>
        </div>
        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-label">Scheduled Meetings</span>
            </div>
            <div class="stat-value"><%= stats.meetings.scheduled %></div>
            <div style="font-size: 0.85rem; color: var(--gray); margin-top: 0.25rem;"><%= stats.meetings.thisWeek %> this week</div>
        </div>
    </div>

    <!-- Status Overview -->
    <div class="stats-grid" style="margin-bottom: 2rem;">
        <div class="stat-card">
            <div class="stat-label">New</div>
            <div class="stat-value" style="color: var(--info);"><%= statusCounts.new || 0 %></div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Contacted</div>
            <div class="stat-value" style="color: var(--warning);"><%= statusCounts.contacted || 0 %></div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Scheduled</div>
            <div class="stat-value" style="color: var(--accent);"><%= statusCounts.scheduled || 0 %></div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Converted</div>
            <div class="stat-value" style="color: var(--success);"><%= statusCounts.converted || 0 %></div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="charts-grid">
        <!-- Leads Over Time -->
        <div class="card chart-card">
            <div class="card-header">
                <h3 class="card-title">Leads Over Time</h3>
                <select class="form-select" style="width: auto; padding: 0.4rem 0.75rem; font-size: 0.85rem;">
                    <option>Last 6 months</option>
                    <option>Last 3 months</option>
                    <option>Last year</option>
                </select>
            </div>
            <div class="chart-container" id="leadsChart"></div>
        </div>

        <!-- Lead Sources -->
        <div class="card chart-card">
            <div class="card-header">
                <h3 class="card-title">Lead Sources</h3>
            </div>
            <div class="chart-container" id="sourcesChart"></div>
        </div>
    </div>

    <!-- Conversion Funnel -->
    <div class="card" style="margin-bottom: 1.5rem;">
        <div class="card-header">
            <h3 class="card-title">Conversion Funnel</h3>
            <span style="color: var(--gray); font-size: 0.85rem;">Overall pipeline performance</span>
        </div>
        <div id="funnelChart"></div>
    </div>

    <!-- Widgets Row -->
    <div class="widgets-grid">
        <!-- Upcoming Meetings -->
        <div class="card widget-card">
            <div class="card-header">
                <h3 class="card-title">Upcoming Meetings</h3>
                <a href="/calendar" class="btn btn-secondary btn-sm">View All</a>
            </div>
            <% if (upcomingMeetings.length === 0) { %>
                <div class="empty-state" style="padding: 2rem;">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                        <line x1="16" y1="2" x2="16" y2="6"/>
                        <line x1="8" y1="2" x2="8" y2="6"/>
                        <line x1="3" y1="10" x2="21" y2="10"/>
                    </svg>
                    <p>No upcoming meetings</p>
                </div>
            <% } else { %>
                <div class="meetings-list" style="padding: 0;">
                    <% upcomingMeetings.slice(0, 4).forEach(meeting => { %>
                        <div class="meeting-item" style="margin: 0; border-radius: 0; border-left: none; border-right: none; border-top: none;">
                            <div class="meeting-time">
                                <div class="meeting-time-value"><%= new Date(meeting.start_time).toLocaleTimeString('en-AU', { hour: '2-digit', minute: '2-digit' }) %></div>
                                <div class="meeting-time-date"><%= new Date(meeting.start_time).toLocaleDateString('en-AU', { month: 'short', day: 'numeric' }) %></div>
                            </div>
                            <div class="meeting-info">
                                <div class="meeting-title"><%= meeting.title %></div>
                                <div class="meeting-lead"><%= meeting.lead_name %></div>
                            </div>
                            <span class="meeting-type-badge badge badge-<%= meeting.meeting_type %>"><%= meeting.meeting_type %></span>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </div>

        <!-- Cost Summary -->
        <div class="card widget-card">
            <div class="card-header">
                <h3 class="card-title">Cost Summary</h3>
                <span class="badge">This Month</span>
            </div>
            <div style="padding: 0.5rem 0;">
                <div style="display: flex; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid var(--border);">
                    <span style="color: var(--gray);">Total Spend</span>
                    <span style="font-weight: 600;">$<%= stats.costs.total.toLocaleString() %></span>
                </div>
                <div style="display: flex; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid var(--border);">
                    <span style="color: var(--gray);">Cost Per Lead</span>
                    <span style="font-weight: 600; color: var(--accent);">$<%= stats.costs.cpl %></span>
                </div>
                <div style="display: flex; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid var(--border);">
                    <span style="color: var(--gray);">Revenue</span>
                    <span style="font-weight: 600; color: var(--success);">$<%= stats.revenue.total.toLocaleString() %></span>
                </div>
                <div style="display: flex; justify-content: space-between; padding: 0.75rem 0;">
                    <span style="color: var(--gray);">ROI</span>
                    <span style="font-weight: 600; color: var(--success);"><%= stats.costs.total > 0 ? Math.round(((stats.revenue.total - stats.costs.total) / stats.costs.total) * 100) : 0 %>%</span>
                </div>
            </div>
            <a href="/costs" class="btn btn-secondary" style="width: 100%; margin-top: 0.5rem; justify-content: center;">View Details</a>
        </div>
    </div>

    <!-- Recent Activity -->
    <div class="card" style="margin-top: 1.5rem;">
        <div class="card-header">
            <h3 class="card-title">Recent Activity</h3>
        </div>
        <div class="activity-feed">
            <% activityFeed.slice(0, 6).forEach(activity => { %>
                <div class="activity-item">
                    <div class="activity-avatar <%= activity.user === 'System' ? 'system' : '' %>">
                        <%= activity.user_avatar %>
                    </div>
                    <div class="activity-content">
                        <div class="activity-text">
                            <strong><%= activity.user %></strong> <%= activity.action %> <span class="entity"><%= activity.entity %></span>
                        </div>
                        <div class="activity-time"><%= activity.time %></div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

    <!-- Recent Leads -->
    <div class="card" style="margin-top: 1.5rem;">
        <div class="card-header">
            <h3 class="card-title">Recent Leads</h3>
            <a href="/leads" class="btn btn-secondary btn-sm">View All</a>
        </div>

        <% if (recentLeads.length === 0) { %>
            <div class="empty-state">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 48px; height: 48px;">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
                <p>No leads yet. They'll appear here when visitors submit the contact form.</p>
            </div>
        <% } else { %>
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Source</th>
                            <th>Status</th>
                            <th>Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% recentLeads.forEach(lead => { %>
                            <tr>
                                <td><strong><%= lead.name %></strong></td>
                                <td><a href="mailto:<%= lead.email %>"><%= lead.email %></a></td>
                                <td style="color: var(--gray); text-transform: capitalize;"><%= lead.source %></td>
                                <td>
                                    <span class="badge badge-<%= lead.status %>">
                                        <%= lead.status %>
                                    </span>
                                </td>
                                <td style="color: var(--gray);">
                                    <%= new Date(lead.created_at).toLocaleDateString() %>
                                </td>
                                <td>
                                    <a href="/leads/<%= lead.id %>" class="btn btn-secondary btn-sm">
                                        View
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </div>
</main>

<%- include('partials/charts') %>
<%- include('partials/modals') %>

<script>
// Initialize charts with data passed from server
document.addEventListener('DOMContentLoaded', function() {
    // Leads Over Time Chart
    renderLineChart('leadsChart', <%= JSON.stringify(chartData.leadsOverTime) %>, { height: 220 });

    // Lead Sources Pie Chart
    renderPieChart('sourcesChart', <%= JSON.stringify(chartData.leadSources) %>, { size: 140, donut: true });

    // Conversion Funnel
    renderHorizontalBarChart('funnelChart', <%= JSON.stringify(chartData.conversionFunnel) %>);

    // Initialize date picker
    initDatePicker();
});

// Date Picker State
let datePickerState = {
    startDate: null,
    endDate: null,
    preset: '<%= typeof dateRange !== "undefined" && dateRange.preset ? dateRange.preset : "all_time" %>',
    selecting: 'start'
};

// Toggle date picker dropdown
function toggleDatePicker() {
    const picker = document.getElementById('datePicker');
    picker.classList.toggle('active');
    if (picker.classList.contains('active')) {
        renderCalendars();
        highlightActivePreset();
    }
}

function closeDatePicker() {
    document.getElementById('datePicker').classList.remove('active');
}

// Close picker when clicking outside
document.addEventListener('click', function(e) {
    const container = document.querySelector('.date-filter-container');
    if (container && !container.contains(e.target)) {
        closeDatePicker();
    }
});

// Initialize date picker
function initDatePicker() {
    // Set up preset clicks
    document.querySelectorAll('.preset-item').forEach(item => {
        item.addEventListener('click', function() {
            const preset = this.dataset.preset;
            selectPreset(preset);
        });
    });

    // Custom days input
    const customInput = document.getElementById('customDays');
    if (customInput) {
        customInput.addEventListener('change', function() {
            const days = parseInt(this.value) || 30;
            const end = new Date();
            const start = new Date();
            start.setDate(end.getDate() - days + 1);
            setDateRange(start, end, 'custom_' + days);
        });
    }

    // Date inputs
    document.getElementById('dateFrom').addEventListener('change', function() {
        datePickerState.startDate = this.value ? new Date(this.value) : null;
        datePickerState.preset = 'custom';
        updateDateInputs();
        renderCalendars();
    });
    document.getElementById('dateTo').addEventListener('change', function() {
        datePickerState.endDate = this.value ? new Date(this.value) : null;
        datePickerState.preset = 'custom';
        updateDateInputs();
        renderCalendars();
    });

    // Initialize from URL params
    const params = new URLSearchParams(window.location.search);
    if (params.get('from') && params.get('to')) {
        datePickerState.startDate = new Date(params.get('from'));
        datePickerState.endDate = new Date(params.get('to'));
        datePickerState.preset = params.get('preset') || 'custom';
    }
    updateDateInputs();
}

// Select preset
function selectPreset(preset) {
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    let start, end;

    switch(preset) {
        case 'today':
            start = end = new Date(today);
            break;
        case 'yesterday':
            start = end = new Date(today);
            start.setDate(start.getDate() - 1);
            end.setDate(end.getDate() - 1);
            break;
        case 'this_week':
            start = new Date(today);
            const dayOfWeek = start.getDay() || 7;
            start.setDate(start.getDate() - dayOfWeek + 1);
            end = new Date(today);
            break;
        case 'last_7_days':
            start = new Date(today);
            start.setDate(start.getDate() - 6);
            end = new Date(today);
            break;
        case 'last_week':
            end = new Date(today);
            const dow = end.getDay() || 7;
            end.setDate(end.getDate() - dow);
            start = new Date(end);
            start.setDate(start.getDate() - 6);
            break;
        case 'last_14_days':
            start = new Date(today);
            start.setDate(start.getDate() - 13);
            end = new Date(today);
            break;
        case 'this_month':
            start = new Date(today.getFullYear(), today.getMonth(), 1);
            end = new Date(today);
            break;
        case 'last_30_days':
            start = new Date(today);
            start.setDate(start.getDate() - 29);
            end = new Date(today);
            break;
        case 'last_month':
            start = new Date(today.getFullYear(), today.getMonth() - 1, 1);
            end = new Date(today.getFullYear(), today.getMonth(), 0);
            break;
        case 'all_time':
            start = null;
            end = null;
            break;
        default:
            start = end = null;
    }

    setDateRange(start, end, preset);
}

function setDateRange(start, end, preset) {
    datePickerState.startDate = start;
    datePickerState.endDate = end;
    datePickerState.preset = preset;
    updateDateInputs();
    highlightActivePreset();
    renderCalendars();
}

function updateDateInputs() {
    const fromInput = document.getElementById('dateFrom');
    const toInput = document.getElementById('dateTo');
    if (datePickerState.startDate) {
        fromInput.value = formatDateISO(datePickerState.startDate);
    } else {
        fromInput.value = '';
    }
    if (datePickerState.endDate) {
        toInput.value = formatDateISO(datePickerState.endDate);
    } else {
        toInput.value = '';
    }
}

function highlightActivePreset() {
    document.querySelectorAll('.preset-item').forEach(item => {
        item.classList.remove('active');
        if (item.dataset.preset === datePickerState.preset) {
            item.classList.add('active');
        }
    });
}

// Apply date filter
function applyDateFilter() {
    const params = new URLSearchParams();
    if (datePickerState.startDate) {
        params.set('from', formatDateISO(datePickerState.startDate));
    }
    if (datePickerState.endDate) {
        params.set('to', formatDateISO(datePickerState.endDate));
    }
    if (datePickerState.preset) {
        params.set('preset', datePickerState.preset);
    }
    window.location.href = '/dashboard' + (params.toString() ? '?' + params.toString() : '');
}

// Format date as YYYY-MM-DD
function formatDateISO(date) {
    if (!date) return '';
    const d = new Date(date);
    const year = d.getFullYear();
    const month = String(d.getMonth() + 1).padStart(2, '0');
    const day = String(d.getDate()).padStart(2, '0');
    return `${year}-${month}-${day}`;
}

// Format date for display
function formatDateDisplay(date) {
    if (!date) return '';
    return new Date(date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

// Render calendars
function renderCalendars() {
    const container = document.getElementById('calendarContainer');
    const today = new Date();
    let html = '';

    // Show current month and previous month
    for (let offset = 1; offset >= 0; offset--) {
        const month = new Date(today.getFullYear(), today.getMonth() - offset, 1);
        html += renderMonth(month);
    }

    container.innerHTML = html;

    // Add click handlers to days
    container.querySelectorAll('.calendar-day:not(.empty):not(.disabled)').forEach(day => {
        day.addEventListener('click', function() {
            const date = new Date(this.dataset.date);
            handleDayClick(date);
        });
    });
}

function renderMonth(monthDate) {
    const monthNames = ['JAN', 'FEB', 'MAR', 'APR', 'MAY', 'JUN', 'JUL', 'AUG', 'SEP', 'OCT', 'NOV', 'DEC'];
    const weekdays = ['M', 'T', 'W', 'T', 'F', 'S', 'S'];
    const year = monthDate.getFullYear();
    const month = monthDate.getMonth();
    const firstDay = new Date(year, month, 1);
    const lastDay = new Date(year, month + 1, 0);
    const today = new Date();
    today.setHours(0, 0, 0, 0);

    let html = `<div class="calendar-month">`;
    html += `<div class="calendar-month-title">${monthNames[month]} ${year}</div>`;
    html += `<div class="calendar-weekdays">`;
    weekdays.forEach(d => { html += `<div class="calendar-weekday">${d}</div>`; });
    html += `</div>`;
    html += `<div class="calendar-days">`;

    // Empty cells for days before first day of month (Monday-based week)
    let startDay = firstDay.getDay() || 7; // Convert Sunday (0) to 7
    for (let i = 1; i < startDay; i++) {
        html += `<div class="calendar-day empty"></div>`;
    }

    // Days of month
    for (let day = 1; day <= lastDay.getDate(); day++) {
        const date = new Date(year, month, day);
        date.setHours(0, 0, 0, 0);
        const dateStr = formatDateISO(date);
        let classes = ['calendar-day'];

        if (date > today) {
            classes.push('disabled');
        } else {
            if (date.getTime() === today.getTime()) classes.push('today');

            // Check if in range
            if (datePickerState.startDate && datePickerState.endDate) {
                const start = new Date(datePickerState.startDate).setHours(0,0,0,0);
                const end = new Date(datePickerState.endDate).setHours(0,0,0,0);
                const current = date.getTime();

                if (current === start && current === end) {
                    classes.push('selected');
                } else if (current === start) {
                    classes.push('range-start');
                } else if (current === end) {
                    classes.push('range-end');
                } else if (current > start && current < end) {
                    classes.push('in-range');
                }
            } else if (datePickerState.startDate) {
                const start = new Date(datePickerState.startDate).setHours(0,0,0,0);
                if (date.getTime() === start) classes.push('selected');
            }
        }

        html += `<div class="${classes.join(' ')}" data-date="${dateStr}">${day}</div>`;
    }

    html += `</div></div>`;
    return html;
}

function handleDayClick(date) {
    if (datePickerState.selecting === 'start' || !datePickerState.startDate) {
        datePickerState.startDate = date;
        datePickerState.endDate = null;
        datePickerState.selecting = 'end';
    } else {
        if (date < datePickerState.startDate) {
            datePickerState.endDate = datePickerState.startDate;
            datePickerState.startDate = date;
        } else {
            datePickerState.endDate = date;
        }
        datePickerState.selecting = 'start';
    }
    datePickerState.preset = 'custom';
    highlightActivePreset();
    updateDateInputs();
    renderCalendars();
}
</script>
