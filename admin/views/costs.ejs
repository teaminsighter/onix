<% var currentPage = 'costs'; %>
<%- include('partials/sidebar', { user, active: 'costs' }) %>

<main class="main">
    <div class="page-header">
        <div>
            <h1 class="page-title">Costs & ROI</h1>
        </div>
        <div class="header-actions">
            <%- include('partials/date-picker') %>
            <button class="btn btn-secondary" onclick="openDealModal()">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
                Add Deal
            </button>
            <button class="btn btn-primary" onclick="openCostModal()">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
                Add Cost Entry
            </button>
        </div>
    </div>

    <!-- ROI Overview Cards -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-label">Total Spend (This Month)</span>
            </div>
            <div class="stat-value">$<%= (stats.totalSpend || 0).toLocaleString() %></div>
        </div>
        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-label">Cost Per Lead</span>
            </div>
            <div class="stat-value accent">$<%= stats.cpl %></div>
        </div>
        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-label">Revenue (This Month)</span>
            </div>
            <div class="stat-value" style="color: var(--success);">$<%= (stats.totalRevenue || 0).toLocaleString() %></div>
        </div>
        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-label">ROI</span>
            </div>
            <div class="stat-value" style="color: var(--success);"><%= stats.roi %>%</div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="costs-grid">
        <!-- Cost by Source Chart -->
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Cost by Source</h3>
                <select class="form-select" style="width: auto; padding: 0.4rem 0.75rem;">
                    <option>April 2026</option>
                    <option>March 2026</option>
                    <option>February 2026</option>
                </select>
            </div>
            <div class="chart-container" id="costSourceChart"></div>
        </div>

        <!-- Cost vs Revenue Chart -->
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Cost vs Revenue Trend</h3>
            </div>
            <div class="chart-container" id="costRevenueChart"></div>
        </div>
    </div>

    <!-- Cost Entries Table -->
    <div class="card" style="margin-bottom: 1.5rem;">
        <div class="card-header">
            <h3 class="card-title">Cost Entries</h3>
            <div class="filters" style="display: flex; gap: 0.75rem;">
                <select class="form-select" style="width: auto; padding: 0.4rem 0.75rem;" id="costSourceFilter">
                    <option value="">All Sources</option>
                    <% var seenSources = []; costs.forEach(function(c) { if (c.source && seenSources.indexOf(c.source) === -1) seenSources.push(c.source); }); seenSources.sort().forEach(function(s) { %>
                        <option value="<%= s %>" style="text-transform:capitalize;"><%= s %></option>
                    <% }); %>
                </select>
                <select class="form-select" style="width: auto; padding: 0.4rem 0.75rem;" id="costMonthFilter">
                    <option value="">All Months</option>
                    <% var seenMonths = []; costs.forEach(function(c) { if (c.month && seenMonths.indexOf(c.month) === -1) seenMonths.push(c.month); }); seenMonths.sort().reverse().forEach(function(m) { %>
                        <option value="<%= m %>"><%= new Date(m + '-01').toLocaleDateString('en-AU', { month: 'long', year: 'numeric' }) %></option>
                    <% }); %>
                </select>
            </div>
        </div>
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Month</th>
                        <th>Source</th>
                        <th>Campaign</th>
                        <th>Amount</th>
                        <th>Leads</th>
                        <th>CPL</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% costs.forEach(cost => { %>
                        <tr data-source="<%= cost.source %>" data-month="<%= cost.month %>">
                            <td><%= new Date(cost.month + '-01').toLocaleDateString('en-AU', { month: 'short', year: 'numeric' }) %></td>
                            <td style="text-transform: capitalize;"><%= cost.source %></td>
                            <td><%= cost.campaign_name || '-' %></td>
                            <td style="font-weight: 600;">$<%= cost.amount.toLocaleString() %></td>
                            <td><%= cost.leads_count %></td>
                            <td style="color: var(--accent);">
                                $<%= cost.leads_count > 0 ? (cost.amount / cost.leads_count).toFixed(2) : '-' %>
                            </td>
                            <td>
                                <button class="btn btn-secondary btn-sm" onclick="editCost(<%= cost.id %>)">Edit</button>
                                <button class="btn btn-secondary btn-sm" style="color: var(--danger);" onclick="deleteCost(<%= cost.id %>)">Delete</button>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Deals/Revenue Table -->
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Deals & Revenue</h3>
            <div style="display: flex; gap: 0.5rem; align-items: center;">
                <span style="color: var(--success); font-weight: 600;">
                    Won: $<%= deals.filter(d => d.status === 'won').reduce((sum, d) => sum + d.amount, 0).toLocaleString() %>
                </span>
                <span style="color: var(--gray);">|</span>
                <span style="color: var(--warning); font-weight: 600;">
                    Pending: $<%= deals.filter(d => d.status === 'pending').reduce((sum, d) => sum + d.amount, 0).toLocaleString() %>
                </span>
            </div>
        </div>
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Lead</th>
                        <th>Deal Title</th>
                        <th>Amount</th>
                        <th>Source</th>
                        <th>Status</th>
                        <th>Closed Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% deals.forEach(deal => { %>
                        <tr>
                            <td>
                                <a href="/leads/<%= deal.lead_id %>" style="color: var(--white); font-weight: 500;">
                                    <%= deal.lead_name %>
                                </a>
                            </td>
                            <td><%= deal.title %></td>
                            <td style="font-weight: 600; color: <%= deal.status === 'won' ? 'var(--success)' : deal.status === 'lost' ? 'var(--danger)' : 'var(--white)' %>;">
                                $<%= deal.amount.toLocaleString() %>
                            </td>
                            <td style="text-transform: capitalize; color: var(--gray);"><%= deal.source %></td>
                            <td>
                                <span class="badge badge-<%= deal.status %>"><%= deal.status %></span>
                            </td>
                            <td style="color: var(--gray);">
                                <%= deal.closed_at ? new Date(deal.closed_at).toLocaleDateString('en-AU') : '-' %>
                            </td>
                            <td>
                                <button class="btn btn-secondary btn-sm" onclick="editDeal(<%= deal.id %>)">Edit</button>
                                <% if (deal.status === 'pending') { %>
                                    <button class="btn btn-secondary btn-sm" style="color: var(--success);" onclick="markDealWon(<%= deal.id %>)">Won</button>
                                    <button class="btn btn-secondary btn-sm" style="color: var(--danger);" onclick="markDealLost(<%= deal.id %>)">Lost</button>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</main>

<%- include('partials/charts') %>
<%- include('partials/modals') %>

<script>
// Initialize charts
document.addEventListener('DOMContentLoaded', function() {
    renderPieChart('costSourceChart', <%= JSON.stringify(chartData.costBySource) %>, { size: 140, donut: true });
    renderDualAxisChart('costRevenueChart', <%= JSON.stringify(chartData.costVsRevenue) %>, { height: 220 });
});

// Filter functionality
document.getElementById('costSourceFilter').addEventListener('change', filterCosts);
document.getElementById('costMonthFilter').addEventListener('change', filterCosts);

function filterCosts() {
    const sourceFilter = document.getElementById('costSourceFilter').value;
    const monthFilter = document.getElementById('costMonthFilter').value;

    document.querySelectorAll('tbody tr[data-source]').forEach(row => {
        const source = row.dataset.source;
        const month = row.dataset.month;

        const sourceMatch = !sourceFilter || source === sourceFilter;
        const monthMatch = !monthFilter || month === monthFilter;

        row.style.display = (sourceMatch && monthMatch) ? '' : 'none';
    });
}

// Action functions
function editCost(id) {
    fetch('/api/costs/' + id).then(function(r) { return r.json(); }).then(function(cost) {
        openModal('Edit Cost Entry', '<form id="editCostForm" onsubmit="submitEditCost(event, ' + id + ')">' +
            '<div class="form-group"><label class="form-label">Source</label><input class="form-input" name="source" value="' + escapeHtml(cost.source) + '" required></div>' +
            '<div class="form-group"><label class="form-label">Amount ($)</label><input class="form-input" name="amount" type="number" step="0.01" value="' + cost.amount + '" required></div>' +
            '<div class="form-group"><label class="form-label">Month</label><input class="form-input" name="month" type="month" value="' + cost.month + '" required></div>' +
            '<div class="form-group"><label class="form-label">Campaign</label><input class="form-input" name="campaign_name" value="' + escapeHtml(cost.campaign_name || '') + '"></div>' +
            '<div class="form-group"><label class="form-label">Leads Count</label><input class="form-input" name="leads_count" type="number" value="' + (cost.leads_count || 0) + '"></div>' +
            '<div class="form-group"><label class="form-label">Notes</label><textarea class="form-textarea" name="notes">' + escapeHtml(cost.notes || '') + '</textarea></div>' +
            '<button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;margin-top:0.5rem;">Save Changes</button></form>');
    });
}

function submitEditCost(e, id) {
    e.preventDefault();
    var fd = new FormData(e.target);
    fetch('/api/costs/' + id, {
        method: 'PUT', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ source: fd.get('source'), amount: fd.get('amount'), month: fd.get('month'), campaign_name: fd.get('campaign_name'), leads_count: fd.get('leads_count'), notes: fd.get('notes') })
    }).then(function(r) { if (r.ok) { showToast('Cost updated', 'success'); closeModal(); window.location.reload(); } else showToast('Failed to update', 'error'); });
}

function deleteCost(id) {
    if (!confirm('Delete this cost entry?')) return;
    fetch('/api/costs/' + id, { method: 'DELETE' }).then(function(r) {
        if (r.ok) { showToast('Cost deleted', 'success'); window.location.reload(); }
        else showToast('Failed to delete', 'error');
    });
}

function editDeal(id) {
    fetch('/api/costs/deals/' + id).then(function(r) { return r.json(); }).then(function(deal) {
        openModal('Edit Deal', '<form id="editDealForm" onsubmit="submitEditDeal(event, ' + id + ')">' +
            '<div class="form-group"><label class="form-label">Title</label><input class="form-input" name="title" value="' + escapeHtml(deal.title) + '" required></div>' +
            '<div class="form-group"><label class="form-label">Amount ($)</label><input class="form-input" name="amount" type="number" step="0.01" value="' + deal.amount + '" required></div>' +
            '<div class="form-group"><label class="form-label">Source</label><input class="form-input" name="source" value="' + escapeHtml(deal.source || '') + '"></div>' +
            '<div class="form-group"><label class="form-label">Notes</label><textarea class="form-textarea" name="notes">' + escapeHtml(deal.notes || '') + '</textarea></div>' +
            '<button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;margin-top:0.5rem;">Save Changes</button></form>');
    });
}

function submitEditDeal(e, id) {
    e.preventDefault();
    var fd = new FormData(e.target);
    fetch('/api/costs/deals/' + id, {
        method: 'PUT', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title: fd.get('title'), amount: fd.get('amount'), source: fd.get('source'), notes: fd.get('notes') })
    }).then(function(r) { if (r.ok) { showToast('Deal updated', 'success'); closeModal(); window.location.reload(); } else showToast('Failed to update', 'error'); });
}

function markDealWon(id) {
    if (!confirm('Mark this deal as won?')) return;
    fetch('/api/costs/deals/' + id + '/status', {
        method: 'PATCH', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: 'won' })
    }).then(function(r) { if (r.ok) { showToast('Deal marked as won', 'success'); window.location.reload(); } else showToast('Failed', 'error'); });
}

function markDealLost(id) {
    if (!confirm('Mark this deal as lost?')) return;
    fetch('/api/costs/deals/' + id + '/status', {
        method: 'PATCH', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: 'lost' })
    }).then(function(r) { if (r.ok) { showToast('Deal marked as lost', 'success'); window.location.reload(); } else showToast('Failed', 'error'); });
}
</script>
