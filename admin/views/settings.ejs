<%- include('partials/sidebar', { user, active: 'settings' }) %>

<main class="main">
    <div class="page-header">
        <h1 class="page-title">Settings</h1>
    </div>

    <div class="settings-layout">
        <!-- Settings Tabs -->
        <div class="settings-tabs">
            <button class="settings-tab active" data-tab="company">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
                Company Profile
            </button>
            <button class="settings-tab" data-tab="integrations">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                </svg>
                Integrations
            </button>
            <button class="settings-tab" data-tab="notifications">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                </svg>
                Notifications
            </button>
            <button class="settings-tab" data-tab="data">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>
                </svg>
                Data & Export
            </button>
        </div>

        <!-- Settings Content -->
        <div class="settings-content">
            <!-- Company Profile Tab -->
            <div class="settings-panel active" id="companyPanel">
                <div class="card">
                    <h3 class="card-title" style="margin-bottom: 1.5rem;">Company Information</h3>

                    <form id="companyForm">
                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label">Company Name</label>
                                <input type="text" class="form-input" name="name" value="<%= companyProfile.name %>">
                            </div>
                            <div class="form-group">
                                <label class="form-label">Email</label>
                                <input type="email" class="form-input" name="email" value="<%= companyProfile.email %>">
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label">Phone</label>
                                <input type="tel" class="form-input" name="phone" value="<%= companyProfile.phone %>">
                            </div>
                            <div class="form-group">
                                <label class="form-label">Timezone</label>
                                <select class="form-select" name="timezone">
                                    <option value="Australia/Sydney" <%= companyProfile.timezone === 'Australia/Sydney' ? 'selected' : '' %>>Australia/Sydney (AEST)</option>
                                    <option value="Australia/Melbourne" <%= companyProfile.timezone === 'Australia/Melbourne' ? 'selected' : '' %>>Australia/Melbourne (AEST)</option>
                                    <option value="Australia/Brisbane" <%= companyProfile.timezone === 'Australia/Brisbane' ? 'selected' : '' %>>Australia/Brisbane (AEST)</option>
                                    <option value="Australia/Perth" <%= companyProfile.timezone === 'Australia/Perth' ? 'selected' : '' %>>Australia/Perth (AWST)</option>
                                </select>
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Address</label>
                            <input type="text" class="form-input" name="address" value="<%= companyProfile.address %>">
                        </div>

                        <button type="button" class="btn btn-primary" onclick="saveCompanyProfile()">Save Changes</button>
                    </form>

                    <!-- Branding Assets -->
                    <div style="margin-top:2rem; padding-top:1.5rem; border-top:1px solid var(--border);">
                        <h3 class="card-title" style="margin-bottom:1rem;">Branding Assets</h3>
                        <p style="color:var(--gray);font-size:0.85rem;margin-bottom:1.5rem;">Upload your favicon and social media image. These will be used on the main website.</p>

                        <!-- Favicon -->
                        <div style="display:flex;align-items:center;gap:1.5rem;padding:1rem;background:var(--bg3);border-radius:8px;margin-bottom:1rem;">
                            <div id="faviconPreview" style="width:48px;height:48px;background:var(--bg);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                <% var faviconUrl = typeof brandingAssets !== 'undefined' && brandingAssets.favicon; %>
                                <% if (faviconUrl) { %>
                                    <img src="<%= faviconUrl %>" style="width:32px;height:32px;object-fit:contain;">
                                <% } else { %>
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--gray)" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                                <% } %>
                            </div>
                            <div style="flex:1;">
                                <div style="font-weight:500;">Favicon</div>
                                <div style="color:var(--gray);font-size:0.8rem;">Browser tab icon — PNG or ICO, 32x32 or 16x16</div>
                            </div>
                            <div>
                                <input type="file" id="faviconInput" accept=".png,.ico,.svg,.jpg" style="display:none;" onchange="uploadBrandingFile('favicon', this)">
                                <button class="btn btn-secondary btn-sm" onclick="document.getElementById('faviconInput').click()">Upload</button>
                            </div>
                        </div>

                        <!-- OG Image -->
                        <div style="display:flex;align-items:center;gap:1.5rem;padding:1rem;background:var(--bg3);border-radius:8px;margin-bottom:1rem;">
                            <div id="ogPreview" style="width:80px;height:48px;background:var(--bg);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;overflow:hidden;">
                                <% var ogUrl = typeof brandingAssets !== 'undefined' && brandingAssets.ogImage; %>
                                <% if (ogUrl) { %>
                                    <img src="<%= ogUrl %>" style="width:100%;height:100%;object-fit:cover;">
                                <% } else { %>
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--gray)" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                                <% } %>
                            </div>
                            <div style="flex:1;">
                                <div style="font-weight:500;">Social Share Image (OG Image)</div>
                                <div style="color:var(--gray);font-size:0.8rem;">Shown when sharing links on social media — PNG or JPG, 1200x630 recommended</div>
                            </div>
                            <div>
                                <input type="file" id="ogInput" accept=".png,.jpg,.jpeg,.webp" style="display:none;" onchange="uploadBrandingFile('og-image', this)">
                                <button class="btn btn-secondary btn-sm" onclick="document.getElementById('ogInput').click()">Upload</button>
                            </div>
                        </div>

                        <!-- Company Logo -->
                        <div style="display:flex;align-items:center;gap:1.5rem;padding:1rem;background:var(--bg3);border-radius:8px;">
                            <div id="logoPreview" style="width:48px;height:48px;background:var(--bg);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;overflow:hidden;">
                                <% if (companyProfile.logo_url) { %>
                                    <img src="<%= companyProfile.logo_url %>" style="width:100%;height:100%;object-fit:contain;">
                                <% } else { %>
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--gray)" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                                <% } %>
                            </div>
                            <div style="flex:1;">
                                <div style="font-weight:500;">Company Logo</div>
                                <div style="color:var(--gray);font-size:0.8rem;">Used in emails and reports — PNG, JPG, or SVG, max 5MB</div>
                            </div>
                            <div>
                                <input type="file" id="logoInput" accept=".png,.jpg,.jpeg,.svg,.webp" style="display:none;" onchange="uploadBrandingFile('logo', this)">
                                <button class="btn btn-secondary btn-sm" onclick="document.getElementById('logoInput').click()">Upload</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Integrations Tab -->
            <div class="settings-panel" id="integrationsPanel">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Connected Services</h3>
                        <% var serviceIntegrations = integrations.filter(function(i) { return ['calendly','formspree','slack'].indexOf(i.name) !== -1; }); %>
                        <span style="color: var(--gray); font-size: 0.9rem;"><%= serviceIntegrations.filter(function(i) { return i.enabled; }).length %> of <%= serviceIntegrations.length %> connected</span>
                    </div>

                    <div class="integrations-list">
                        <% serviceIntegrations.forEach(function(integration) { %>
                            <div class="integration-item" id="integration-<%= integration.name %>">
                                <div class="integration-info">
                                    <div class="integration-icon">
                                        <% if (integration.icon === 'calendar') { %>
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                        <% } else if (integration.icon === 'message-square') { %>
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                                        <% } else { %>
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                                        <% } %>
                                    </div>
                                    <div>
                                        <h4 class="integration-name"><%= integration.label %></h4>
                                        <p class="integration-description"><%= integration.description %></p>
                                        <% if (integration.enabled) { %>
                                            <span class="badge badge-converted" style="margin-top:0.25rem;font-size:0.7rem;">Connected</span>
                                        <% } %>
                                    </div>
                                </div>
                                <div class="integration-actions">
                                    <button class="btn btn-secondary btn-sm" onclick="configureIntegration('<%= integration.name %>')">Configure</button>
                                    <label class="toggle">
                                        <input type="checkbox" <%= integration.enabled ? 'checked' : '' %> onchange="toggleIntegration('<%= integration.name %>', this.checked)">
                                        <span class="toggle-slider"></span>
                                    </label>
                                </div>
                            </div>
                        <% }) %>
                    </div>

                    <!-- Custom Header Scripts -->
                    <div style="margin-top:1.5rem;">
                        <h3 class="card-title" style="margin-bottom:1rem;">Custom Header Scripts</h3>
                        <p style="color:var(--gray);font-size:0.85rem;margin-bottom:1rem;">Add any tracking or analytics scripts (Google Analytics, Facebook Pixel, Hotjar, etc.) to be injected into the website's <code>&lt;head&gt;</code> section.</p>
                        <div class="form-group">
                            <label class="form-label">Header Scripts</label>
                            <textarea
                                class="form-textarea"
                                id="headerScripts"
                                rows="12"
                                placeholder="<!-- Paste your tracking scripts here -->
<!-- Example: Google Analytics -->
<script async src='https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX'></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-XXXXXXXXXX');
</script>"
                                style="font-family: monospace; font-size: 0.85rem; background: var(--bg); border: 1px solid var(--border); resize: vertical; min-height: 200px;"><%= (integrations.find(function(i){ return i.name === 'header_scripts'; }) || {config:{}}).config.scripts || '' %></textarea>
                        </div>
                        <div style="display:flex;gap:0.75rem;align-items:center;">
                            <button class="btn btn-primary" onclick="saveHeaderScripts()">Save Scripts</button>
                            <span id="headerScriptStatus" style="color:var(--gray);font-size:0.85rem;"></span>
                        </div>
                        <p style="color:var(--gray);font-size:0.8rem;margin-top:0.75rem;">
                            <strong>Note:</strong> Scripts will be automatically injected into the main website's <code>&lt;head&gt;</code> section.
                            Make sure to include the full <code>&lt;script&gt;</code> tags.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Notifications Tab -->
            <div class="settings-panel" id="notificationsPanel">
                <div class="card">
                    <h3 class="card-title" style="margin-bottom: 1.5rem;">Notification Preferences</h3>

                    <div class="notification-group">
                        <h4 class="notification-group-title">Lead Notifications</h4>
                        <div class="notification-item">
                            <div class="notification-info">
                                <span class="notification-label">Email me when a new lead is received</span>
                                <span class="notification-description">Get instant email alerts for new form submissions</span>
                            </div>
                            <label class="toggle">
                                <input type="checkbox" <%= notificationPreferences.new_lead_email ? 'checked' : '' %> name="new_lead_email">
                                <span class="toggle-slider"></span>
                            </label>
                        </div>
                        <div class="notification-item">
                            <div class="notification-info">
                                <span class="notification-label">Slack notification for new leads</span>
                                <span class="notification-description">Post to Slack channel when leads come in</span>
                            </div>
                            <label class="toggle">
                                <input type="checkbox" <%= notificationPreferences.new_lead_slack ? 'checked' : '' %> name="new_lead_slack">
                                <span class="toggle-slider"></span>
                            </label>
                        </div>
                    </div>

                    <div class="notification-group">
                        <h4 class="notification-group-title">Meeting Notifications</h4>
                        <div class="notification-item">
                            <div class="notification-info">
                                <span class="notification-label">Meeting reminders</span>
                                <span class="notification-description">Get reminded before scheduled meetings</span>
                            </div>
                            <label class="toggle">
                                <input type="checkbox" <%= notificationPreferences.meeting_reminder ? 'checked' : '' %> name="meeting_reminder">
                                <span class="toggle-slider"></span>
                            </label>
                        </div>
                        <div class="notification-item">
                            <div class="notification-info">
                                <span class="notification-label">Reminder timing</span>
                                <span class="notification-description">How early to send meeting reminders</span>
                            </div>
                            <select class="form-select" style="width: auto;" name="meeting_reminder_minutes">
                                <option value="15" <%= notificationPreferences.meeting_reminder_minutes === 15 ? 'selected' : '' %>>15 minutes before</option>
                                <option value="30" <%= notificationPreferences.meeting_reminder_minutes === 30 ? 'selected' : '' %>>30 minutes before</option>
                                <option value="60" <%= notificationPreferences.meeting_reminder_minutes === 60 ? 'selected' : '' %>>1 hour before</option>
                                <option value="1440" <%= notificationPreferences.meeting_reminder_minutes === 1440 ? 'selected' : '' %>>1 day before</option>
                            </select>
                        </div>
                    </div>

                    <div class="notification-group">
                        <h4 class="notification-group-title">Reports & Summaries</h4>
                        <div class="notification-item">
                            <div class="notification-info">
                                <span class="notification-label">Daily digest</span>
                                <span class="notification-description">Summary of daily activity every morning</span>
                            </div>
                            <label class="toggle">
                                <input type="checkbox" <%= notificationPreferences.daily_digest ? 'checked' : '' %> name="daily_digest">
                                <span class="toggle-slider"></span>
                            </label>
                        </div>
                        <div class="notification-item">
                            <div class="notification-info">
                                <span class="notification-label">Weekly summary</span>
                                <span class="notification-description">Performance report every Monday</span>
                            </div>
                            <label class="toggle">
                                <input type="checkbox" <%= notificationPreferences.weekly_summary ? 'checked' : '' %> name="weekly_summary">
                                <span class="toggle-slider"></span>
                            </label>
                        </div>
                    </div>

                    <button type="button" class="btn btn-primary" onclick="saveNotificationPrefs()">Save Preferences</button>
                </div>
            </div>

            <!-- Data & Export Tab -->
            <div class="settings-panel" id="dataPanel">
                <div class="card">
                    <h3 class="card-title" style="margin-bottom: 1.5rem;">Export Data</h3>

                    <div class="export-options">
                        <div class="export-item">
                            <div class="export-info">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2">
                                    <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><polyline points="17 11 19 13 23 9"/>
                                </svg>
                                <div>
                                    <h4>Export Leads</h4>
                                    <p>Download all leads as CSV file</p>
                                </div>
                            </div>
                            <button class="btn btn-secondary" onclick="exportLeads()">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
                                </svg>
                                Export CSV
                            </button>
                        </div>

                        <div class="export-item">
                            <div class="export-info">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2">
                                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                                </svg>
                                <div>
                                    <h4>Export Meetings</h4>
                                    <p>Download meeting history as CSV</p>
                                </div>
                            </div>
                            <button class="btn btn-secondary" onclick="exportMeetings()">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
                                </svg>
                                Export CSV
                            </button>
                        </div>

                        <div class="export-item">
                            <div class="export-info">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2">
                                    <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                                </svg>
                                <div>
                                    <h4>Export Financial Data</h4>
                                    <p>Download costs and revenue data</p>
                                </div>
                            </div>
                            <button class="btn btn-secondary" onclick="exportFinancials()">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
                                </svg>
                                Export CSV
                            </button>
                        </div>

                        <div class="export-item">
                            <div class="export-info">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2">
                                    <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>
                                </svg>
                                <div>
                                    <h4>Export Analytics Report</h4>
                                    <p>Download comprehensive analytics PDF</p>
                                </div>
                            </div>
                            <button class="btn btn-secondary" onclick="exportAnalytics()">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
                                </svg>
                                Export PDF
                            </button>
                        </div>
                    </div>
                </div>

                <div class="card" style="margin-top: 1.5rem;">
                    <h3 class="card-title" style="margin-bottom: 1rem; color: var(--danger);">Danger Zone</h3>
                    <p style="color: var(--gray); margin-bottom: 1.5rem;">These actions are destructive and cannot be undone.</p>

                    <div class="danger-actions">
                        <div class="danger-item">
                            <div>
                                <h4>Clear All Leads</h4>
                                <p style="color: var(--gray); font-size: 0.9rem;">Permanently delete all lead data</p>
                            </div>
                            <button class="btn btn-secondary" style="color: var(--danger); border-color: var(--danger);" onclick="clearAllLeads()">
                                Clear Leads
                            </button>
                        </div>
                        <div class="danger-item">
                            <div>
                                <h4>Reset All Data</h4>
                                <p style="color: var(--gray); font-size: 0.9rem;">Delete everything and start fresh</p>
                            </div>
                            <button class="btn btn-secondary" style="color: var(--danger); border-color: var(--danger);" onclick="resetAllData()">
                                Reset Data
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<%- include('partials/modals') %>

<script>
// Tab switching
document.querySelectorAll('.settings-tab').forEach(tab => {
    tab.addEventListener('click', () => {
        document.querySelectorAll('.settings-tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.settings-panel').forEach(p => p.classList.remove('active'));

        tab.classList.add('active');
        document.getElementById(tab.dataset.tab + 'Panel').classList.add('active');
    });
});

function saveCompanyProfile() {
    var fd = new FormData(document.getElementById('companyForm'));
    fetch('/api/settings/company', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(Object.fromEntries(fd))
    }).then(function(r) {
        if (r.ok) showToast('Company profile saved', 'success');
        else showToast('Failed to save', 'error');
    });
}

function toggleIntegration(name, enabled) {
    fetch('/api/settings/integrations/' + name, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ enabled: enabled })
    }).then(function(r) {
        if (r.ok) {
            showToast(name + (enabled ? ' enabled' : ' disabled'), 'success');
            // Auto-open configure modal when enabling
            if (enabled) {
                setTimeout(function() { configureIntegration(name); }, 300);
            }
            // Reload to update "Connected" badges
            setTimeout(function() { window.location.reload(); }, 1500);
        }
        else showToast('Failed to update', 'error');
    });
}

function saveHeaderScripts() {
    var scripts = document.getElementById('headerScripts').value;
    var statusEl = document.getElementById('headerScriptStatus');
    statusEl.textContent = 'Saving...';
    statusEl.style.color = 'var(--gray)';

    fetch('/api/settings/integrations/header_scripts/config', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ scripts: scripts })
    }).then(function(r) {
        if (r.ok) {
            showToast('Header scripts saved', 'success');
            statusEl.textContent = 'Saved!';
            statusEl.style.color = 'var(--success)';
            setTimeout(function() { statusEl.textContent = ''; }, 3000);
        } else {
            showToast('Failed to save scripts', 'error');
            statusEl.textContent = 'Error saving';
            statusEl.style.color = 'var(--danger)';
        }
    }).catch(function() {
        showToast('Failed to save scripts', 'error');
        statusEl.textContent = 'Error saving';
        statusEl.style.color = 'var(--danger)';
    });
}

function configureIntegration(name) {
    var fields = '';
    if (name === 'calendly') {
        fields = '<div class="form-group"><label class="form-label">Calendly API Key</label><input type="text" class="form-input" name="api_key" placeholder="Enter your Calendly Personal Access Token"></div>' +
            '<div class="form-group"><label class="form-label">Webhook URL (for Calendly to call)</label><input type="text" class="form-input" readonly value="' + window.location.origin + '/api/webhook/calendly" onclick="this.select()"></div>' +
            '<button type="button" class="btn btn-secondary" onclick="syncCalendly()" style="margin-top:0.5rem;width:100%;justify-content:center;">Sync Past Meetings</button>';
    } else if (name === 'slack') {
        fields = '<div class="form-group"><label class="form-label">Slack Webhook URL</label><input type="text" class="form-input" name="webhook_url" placeholder="https://hooks.slack.com/services/..."></div>';
    } else if (name === 'formspree') {
        fields = '<div class="form-group"><label class="form-label">Formspree Form ID</label><input type="text" class="form-input" name="form_id" placeholder="e.g., xrgvknab"></div>';
    } else {
        fields = '<div class="form-group"><label class="form-label">API Key</label><input type="text" class="form-input" name="api_key" placeholder="Enter API key"></div>';
    }

    var html = '<form onsubmit="submitIntegrationConfig(event, \'' + name + '\')">' +
        '<input type="hidden" name="integration_name" value="' + name + '">' +
        fields +
        '<div style="display:flex;gap:0.75rem;justify-content:flex-end;margin-top:1rem;">' +
        '<button type="button" class="btn btn-secondary" onclick="closeModal()">Cancel</button>' +
        '<button type="submit" class="btn btn-primary">Save Configuration</button></div></form>';

    // Directly set modal content and show it
    document.getElementById('modalTitle').textContent = 'Configure ' + name.charAt(0).toUpperCase() + name.slice(1);
    document.getElementById('modalBody').innerHTML = html;
    document.getElementById('modalOverlay').classList.add('active');
}

function submitIntegrationConfig(e, name) {
    e.preventDefault();
    var fd = new FormData(e.target);
    var config = {};
    fd.forEach(function(v, k) { if (k !== 'integration_name') config[k] = v; });
    fetch('/api/settings/integrations/' + name + '/config', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(config)
    }).then(function(r) {
        if (r.ok) { closeModal(); showToast('Configuration saved', 'success'); }
        else showToast('Failed to save config', 'error');
    });
}

function syncCalendly() {
    showToast('Syncing Calendly events...', 'info');
    fetch('/api/settings/integrations/calendly/sync', { method: 'POST' })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.synced !== undefined) showToast('Synced ' + data.synced + ' meetings from Calendly', 'success');
            else showToast(data.error || 'Sync failed', 'error');
        }).catch(function() { showToast('Sync failed', 'error'); });
}

function saveNotificationPrefs() {
    var data = {
        new_lead_email: document.querySelector('[name="new_lead_email"]')?.checked || false,
        new_lead_slack: document.querySelector('[name="new_lead_slack"]')?.checked || false,
        meeting_reminder: document.querySelector('[name="meeting_reminder"]')?.checked || false,
        meeting_reminder_minutes: parseInt(document.querySelector('[name="meeting_reminder_minutes"]')?.value) || 30,
        weekly_summary: document.querySelector('[name="weekly_summary"]')?.checked || false,
        daily_digest: document.querySelector('[name="daily_digest"]')?.checked || false
    };
    fetch('/api/settings/notifications', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
    }).then(function(r) {
        if (r.ok) showToast('Notification preferences saved', 'success');
        else showToast('Failed to save', 'error');
    });
}

function exportLeads() { window.location.href = '/api/settings/export/leads'; }
function exportMeetings() { window.location.href = '/api/settings/export/meetings'; }
function exportFinancials() { window.location.href = '/api/settings/export/costs'; }
function exportAnalytics() { window.location.href = '/api/settings/export/leads'; showToast('Analytics data exported as leads CSV', 'info'); }

function clearAllLeads() {
    if (!confirm('This will permanently delete ALL leads. Are you sure?')) return;
    fetch('/api/settings/data/leads', {
        method: 'DELETE',
        headers: { 'X-Confirm': 'DELETE_ALL_LEADS' }
    }).then(function(r) {
        if (r.ok) { showToast('All leads cleared', 'success'); window.location.reload(); }
        else showToast('Failed to clear leads', 'error');
    });
}

function resetAllData() {
    var confirm_text = prompt('This will delete ALL data. Type RESET to confirm:');
    if (confirm_text !== 'RESET') return;
    fetch('/api/settings/data/all', {
        method: 'DELETE',
        headers: { 'X-Confirm': 'RESET_ALL_DATA' }
    }).then(function(r) {
        if (r.ok) { showToast('All data reset', 'success'); window.location.reload(); }
        else showToast('Failed to reset data', 'error');
    });
}

function uploadBrandingFile(type, input) {
    if (!input.files || !input.files[0]) return;
    var file = input.files[0];
    if (file.size > 5 * 1024 * 1024) { showToast('File too large (max 5MB)', 'error'); return; }

    var fd = new FormData();
    fd.append('file', file);

    showToast('Uploading ' + type + '...', 'info');
    fetch('/api/settings/upload/' + type, {
        method: 'POST',
        body: fd
    }).then(function(r) { return r.json(); }).then(function(data) {
        if (data.url) {
            showToast(type + ' uploaded successfully', 'success');
            // Update preview
            var previewId = type === 'favicon' ? 'faviconPreview' : type === 'og-image' ? 'ogPreview' : 'logoPreview';
            var previewEl = document.getElementById(previewId);
            if (previewEl) {
                previewEl.innerHTML = '<img src="' + data.url + '?' + Date.now() + '" style="width:100%;height:100%;object-fit:contain;">';
            }
        } else {
            showToast(data.error || 'Upload failed', 'error');
        }
    }).catch(function() { showToast('Upload failed', 'error'); });
    input.value = '';
}
</script>
