<%- include('partials/sidebar', { user, active: 'team' }) %>

<main class="main">
    <div class="page-header">
        <div>
            <a href="/team" class="back-link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M19 12H5M12 19l-7-7 7-7"/>
                </svg>
                Back to Team
            </a>
            <h1 class="page-title"><%= member.full_name %></h1>
        </div>
        <span class="badge badge-<%= member.role %>" style="font-size: 0.9rem; padding: 0.5rem 1rem;">
            <%= member.role %>
        </span>
    </div>

    <div class="detail-grid">
        <!-- Main Content -->
        <div class="detail-main">
            <!-- Profile Card -->
            <div class="card">
                <h3 class="card-title" style="margin-bottom: 1.25rem;">Profile Information</h3>

                <form id="profileForm">
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Full Name</label>
                            <input type="text" class="form-input" name="full_name" value="<%= member.full_name %>">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Username</label>
                            <input type="text" class="form-input" name="username" value="<%= member.username %>" readonly style="opacity: 0.7;">
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-input" name="email" value="<%= member.email %>">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Role</label>
                            <select class="form-select" name="role">
                                <option value="admin" <%= member.role === 'admin' ? 'selected' : '' %>>Admin</option>
                                <option value="manager" <%= member.role === 'manager' ? 'selected' : '' %>>Manager</option>
                                <option value="sales" <%= member.role === 'sales' ? 'selected' : '' %>>Sales</option>
                            </select>
                        </div>
                    </div>

                    <button type="button" class="btn btn-primary" onclick="saveProfile()">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
                            <polyline points="17 21 17 13 7 13 7 21"/>
                            <polyline points="7 3 7 8 15 8"/>
                        </svg>
                        Save Changes
                    </button>
                </form>
            </div>

            <!-- Performance Stats -->
            <div class="card">
                <h3 class="card-title" style="margin-bottom: 1.25rem;">Performance Statistics</h3>

                <div class="stats-grid" style="margin-bottom: 1.5rem;">
                    <div class="stat-card">
                        <div class="stat-label">Leads Contacted</div>
                        <div class="stat-value"><%= member.stats.leads_contacted %></div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">Meetings Scheduled</div>
                        <div class="stat-value accent"><%= member.stats.meetings_scheduled %></div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">Conversions</div>
                        <div class="stat-value" style="color: var(--success);"><%= member.stats.conversions %></div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">Conversion Rate</div>
                        <% const convRate = member.stats.leads_contacted > 0 ? ((member.stats.conversions / member.stats.leads_contacted) * 100).toFixed(1) : 0; %>
                        <div class="stat-value" style="color: <%= convRate >= 25 ? 'var(--success)' : 'var(--warning)' %>;"><%= convRate %>%</div>
                    </div>
                </div>

                <div class="chart-container" id="userPerformanceChart" style="height: 200px;"></div>
            </div>

            <!-- Activity Log -->
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Recent Activity</h3>
                    <button class="btn btn-secondary btn-sm">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                            <polyline points="7 10 12 15 17 10"/>
                            <line x1="12" y1="15" x2="12" y2="3"/>
                        </svg>
                        Export Log
                    </button>
                </div>
                <div class="activity-log">
                    <% userActivity.forEach(activity => { %>
                        <div class="activity-log-item">
                            <div class="activity-log-time">
                                <span class="activity-date"><%= new Date(activity.timestamp).toLocaleDateString('en-AU', { month: 'short', day: 'numeric' }) %></span>
                                <span class="activity-hour"><%= new Date(activity.timestamp).toLocaleTimeString('en-AU', { hour: '2-digit', minute: '2-digit' }) %></span>
                            </div>
                            <div class="activity-log-content">
                                <span class="activity-action <%= activity.type %>"><%= activity.action %></span>
                                <span class="activity-entity"><%= activity.entity %></span>
                            </div>
                        </div>
                    <% }) %>
                </div>
                <div style="padding: 1rem; text-align: center; border-top: 1px solid var(--border);">
                    <button class="btn btn-secondary btn-sm">Load More</button>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="detail-sidebar">
            <!-- Account Status -->
            <div class="card">
                <h3 class="card-title" style="margin-bottom: 1rem;">Account Status</h3>

                <div class="status-info">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                        <span>Status</span>
                        <% if (member.is_active) { %>
                            <span class="badge badge-converted">Active</span>
                        <% } else { %>
                            <span class="badge badge-lost">Inactive</span>
                        <% } %>
                    </div>

                    <div style="font-size: 0.9rem; color: var(--gray); margin-bottom: 1rem;">
                        <div style="display: flex; justify-content: space-between; padding: 0.5rem 0; border-bottom: 1px solid var(--border);">
                            <span>Last Login</span>
                            <span style="color: var(--white);"><%= new Date(member.last_login).toLocaleDateString('en-AU') %></span>
                        </div>
                        <div style="display: flex; justify-content: space-between; padding: 0.5rem 0;">
                            <span>Member Since</span>
                            <span style="color: var(--white);">Jan 15, 2026</span>
                        </div>
                    </div>

                    <div class="action-buttons">
                        <% if (member.is_active) { %>
                            <button class="btn btn-secondary btn-block" onclick="deactivateUser()">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>
                                </svg>
                                Deactivate Account
                            </button>
                        <% } else { %>
                            <button class="btn btn-secondary btn-block" style="color: var(--success);" onclick="activateUser()">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="20 6 9 17 4 12"/>
                                </svg>
                                Activate Account
                            </button>
                        <% } %>

                        <button class="btn btn-secondary btn-block" onclick="resetPassword()">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                            </svg>
                            Reset Password
                        </button>

                        <button class="btn btn-secondary btn-block" style="color: var(--danger);" onclick="deleteUser()">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                            </svg>
                            Delete Account
                        </button>
                    </div>
                </div>
            </div>

            <!-- Assigned Leads -->
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Assigned Leads</h3>
                    <span class="badge"><%= assignedLeads.length %></span>
                </div>
                <div class="assigned-leads-list">
                    <% if (assignedLeads.length > 0) { %>
                        <% assignedLeads.slice(0, 5).forEach(lead => { %>
                            <a href="/leads/<%= lead.id %>" class="assigned-lead-item">
                                <span class="lead-name"><%= lead.name %></span>
                                <span class="badge badge-<%= lead.status %>"><%= lead.status %></span>
                            </a>
                        <% }) %>
                        <% if (assignedLeads.length > 5) { %>
                            <div style="padding: 0.5rem; text-align: center;">
                                <a href="/leads?assigned=<%= member.id %>" style="color: var(--accent); font-size: 0.9rem;">
                                    View all <%= assignedLeads.length %> leads
                                </a>
                            </div>
                        <% } %>
                    <% } else { %>
                        <div class="empty-state" style="padding: 1rem;">
                            <p style="color: var(--gray); font-size: 0.9rem;">No leads assigned</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</main>

<%- include('partials/charts') %>
<%- include('partials/modals') %>

<script>
// Initialize performance chart
document.addEventListener('DOMContentLoaded', function() {
    const performanceData = {
        labels: ['Week 1', 'Week 2', 'Week 3', 'Week 4'],
        data: [12, 15, 18, 14]
    };
    renderBarChart('userPerformanceChart', performanceData, { height: 180, barColor: '#c9f31d' });
});

function saveProfile() {
    const formData = new FormData(document.getElementById('profileForm'));
    console.log('Save profile:', Object.fromEntries(formData));
    alert('Profile saved! (UI Demo)');
}

function deactivateUser() {
    openConfirmModal(
        'Deactivate Account',
        'Are you sure you want to deactivate this account? The user will no longer be able to log in.',
        () => {
            console.log('Deactivate user');
            alert('Account deactivated! (UI Demo)');
        }
    );
}

function activateUser() {
    openConfirmModal(
        'Activate Account',
        'Are you sure you want to activate this account?',
        () => {
            console.log('Activate user');
            alert('Account activated! (UI Demo)');
        }
    );
}

function resetPassword() {
    openConfirmModal(
        'Reset Password',
        'This will send a password reset link to the user\'s email address. Continue?',
        () => {
            console.log('Reset password');
            alert('Password reset email sent! (UI Demo)');
        }
    );
}

function deleteUser() {
    openConfirmModal(
        'Delete Account',
        'This action cannot be undone. All user data will be permanently deleted. Are you absolutely sure?',
        () => {
            console.log('Delete user');
            alert('Account deleted! (UI Demo)');
            window.location.href = '/team';
        }
    );
}
</script>
