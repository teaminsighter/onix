<%- include('partials/sidebar', { user, active: 'leads' }) %>

<main class="main">
    <div class="page-header">
        <div>
            <a href="/leads" style="color: var(--gray); font-size: 0.9rem; display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M19 12H5M12 19l-7-7 7-7"/>
                </svg>
                Back to Leads
            </a>
            <h1 class="page-title"><%= lead.name %></h1>
        </div>
        <span class="badge badge-<%= lead.status %>" style="font-size: 0.9rem; padding: 0.4rem 1rem;">
            <%= lead.status %>
        </span>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 300px; gap: 1.5rem;">
        <!-- Main Info -->
        <div>
            <!-- Contact Info Card -->
            <div class="card" style="margin-bottom: 1.5rem;">
                <h3 class="card-title" style="margin-bottom: 1rem;">Contact Information</h3>

                <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem;">
                    <div>
                        <div style="color: var(--gray); font-size: 0.85rem; margin-bottom: 0.25rem;">Email</div>
                        <a href="mailto:<%= lead.email %>" style="font-weight: 500;"><%= lead.email %></a>
                    </div>

                    <div>
                        <div style="color: var(--gray); font-size: 0.85rem; margin-bottom: 0.25rem;">Phone</div>
                        <% if (lead.phone) { %>
                            <a href="tel:<%= lead.phone %>" style="font-weight: 500;"><%= lead.phone %></a>
                        <% } else { %>
                            <span style="color: var(--gray);">Not provided</span>
                        <% } %>
                    </div>

                    <div>
                        <div style="color: var(--gray); font-size: 0.85rem; margin-bottom: 0.25rem;">Source</div>
                        <span style="text-transform: capitalize;"><%= lead.source %></span>
                    </div>

                    <div>
                        <div style="color: var(--gray); font-size: 0.85rem; margin-bottom: 0.25rem;">Received</div>
                        <span><%= new Date(lead.created_at).toLocaleString() %></span>
                    </div>
                </div>
            </div>

            <!-- Message Card -->
            <% if (lead.message) { %>
                <div class="card" style="margin-bottom: 1.5rem;">
                    <h3 class="card-title" style="margin-bottom: 1rem;">Message</h3>
                    <p style="color: var(--gray-light); line-height: 1.7; white-space: pre-wrap;"><%= lead.message %></p>
                </div>
            <% } %>

            <!-- Notes Card -->
            <div class="card" style="margin-bottom: 1.5rem;">
                <h3 class="card-title" style="margin-bottom: 1rem;">Notes</h3>

                <% if (lead.notes) { %>
                    <div style="color: var(--gray-light); white-space: pre-wrap; margin-bottom: 1rem; padding: 1rem; background: var(--bg); border-radius: 8px;">
                        <%= lead.notes %>
                    </div>
                <% } %>

                <form id="noteForm" style="display: flex; gap: 0.75rem;">
                    <input type="text" id="noteInput" class="form-input" placeholder="Add a note..." style="flex: 1;">
                    <button type="submit" class="btn btn-primary">Add</button>
                </form>
            </div>

            <!-- Activity Timeline -->
            <div class="card">
                <h3 class="card-title" style="margin-bottom: 1rem;">Activity</h3>

                <% if (activities.length === 0) { %>
                    <p style="color: var(--gray);">No activity recorded yet.</p>
                <% } else { %>
                    <div style="border-left: 2px solid var(--border); padding-left: 1rem; margin-left: 0.5rem;">
                        <% activities.forEach(activity => { %>
                            <div style="margin-bottom: 1rem; position: relative;">
                                <div style="position: absolute; left: -1.4rem; top: 0.25rem; width: 8px; height: 8px; background: var(--accent); border-radius: 50%;"></div>
                                <div style="font-size: 0.9rem; font-weight: 500; text-transform: capitalize;">
                                    <%= activity.type.replace(/_/g, ' ') %>
                                </div>
                                <div style="color: var(--gray); font-size: 0.85rem;"><%= activity.description %></div>
                                <div style="color: var(--gray); font-size: 0.75rem; margin-top: 0.25rem;">
                                    <%= new Date(activity.created_at).toLocaleString() %>
                                    <% if (activity.created_by) { %> by <%= activity.created_by %><% } %>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Sidebar Actions -->
        <div>
            <div class="card">
                <h3 class="card-title" style="margin-bottom: 1rem;">Quick Actions</h3>

                <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                    <a href="mailto:<%= lead.email %>" class="btn btn-primary" style="justify-content: center;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                            <polyline points="22,6 12,13 2,6"/>
                        </svg>
                        Send Email
                    </a>

                    <% if (lead.phone) { %>
                        <a href="tel:<%= lead.phone %>" class="btn btn-secondary" style="justify-content: center;">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                            </svg>
                            Call
                        </a>
                    <% } %>
                </div>

                <hr style="border: none; border-top: 1px solid var(--border); margin: 1rem 0;">

                <div class="form-group">
                    <label class="form-label">Update Status</label>
                    <select class="form-select" onchange="updateStatus(<%= lead.id %>, this.value)">
                        <option value="new" <%= lead.status === 'new' ? 'selected' : '' %>>New</option>
                        <option value="contacted" <%= lead.status === 'contacted' ? 'selected' : '' %>>Contacted</option>
                        <option value="scheduled" <%= lead.status === 'scheduled' ? 'selected' : '' %>>Scheduled</option>
                        <option value="converted" <%= lead.status === 'converted' ? 'selected' : '' %>>Converted</option>
                        <option value="lost" <%= lead.status === 'lost' ? 'selected' : '' %>>Lost</option>
                    </select>
                </div>

                <hr style="border: none; border-top: 1px solid var(--border); margin: 1rem 0;">

                <button onclick="deleteLead(<%= lead.id %>)" class="btn btn-secondary" style="width: 100%; justify-content: center; color: var(--danger);">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="3 6 5 6 21 6"/>
                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                    </svg>
                    Delete Lead
                </button>
            </div>
        </div>
    </div>
</main>

<script>
    // Add note
    document.getElementById('noteForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const input = document.getElementById('noteInput');
        const note = input.value.trim();

        if (!note) return;

        const response = await fetch('/api/leads/<%= lead.id %>/notes', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ note })
        });

        if (response.ok) {
            window.location.reload();
        } else {
            showToast('Failed to add note', 'error');
        }
    });

    // Delete lead
    async function deleteLead(id) {
        if (!confirm('Are you sure you want to delete this lead? This cannot be undone.')) {
            return;
        }

        const response = await fetch(`/api/leads/${id}`, { method: 'DELETE' });

        if (response.ok) {
            window.location.href = '/leads';
        } else {
            showToast('Failed to delete lead', 'error');
        }
    }
</script>
