<%# Date Picker Partial - Include in page header %>
<div class="date-filter-container">
    <button class="date-filter-btn" id="dateFilterBtn" onclick="toggleDatePicker()">
        <svg class="calendar-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
            <rect x="7" y="14" width="3" height="3" fill="currentColor" stroke="none"/>
            <rect x="14" y="14" width="3" height="3" fill="currentColor" stroke="none"/>
        </svg>
        <span id="dateFilterLabel"><%= typeof dateRange !== 'undefined' ? (dateRange.label || 'All time') : 'All time' %></span>
        <svg class="dropdown-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="6 9 12 15 18 9"/>
        </svg>
    </button>
    <div class="date-picker-dropdown" id="datePicker">
        <div class="date-picker-layout">
            <div class="date-picker-presets">
                <div class="preset-item" data-preset="today">Today</div>
                <div class="preset-item" data-preset="yesterday">Yesterday</div>
                <div class="preset-item" data-preset="this_week">This week (Mon – Today)</div>
                <div class="preset-item" data-preset="last_7_days">Last 7 days</div>
                <div class="preset-item" data-preset="last_week">Last week (Mon – Sun)</div>
                <div class="preset-item" data-preset="last_14_days">Last 14 days</div>
                <div class="preset-item" data-preset="this_month">This month</div>
                <div class="preset-item" data-preset="last_30_days">Last 30 days</div>
                <div class="preset-item" data-preset="last_month">Last month</div>
                <div class="preset-item active" data-preset="all_time">All time</div>
                <div class="preset-divider"></div>
                <div class="preset-custom">
                    <input type="number" id="customDays" value="30" min="1" max="365" class="custom-days-input">
                    <span>days to today</span>
                </div>
            </div>
            <div class="date-picker-calendar">
                <div class="date-range-display">
                    <span class="date-range-dot"></span>
                    <span>DATE RANGE</span>
                </div>
                <div class="date-range-inputs">
                    <input type="text" id="dateFrom" class="date-input" placeholder="dd/mm/yyyy" readonly>
                    <span>to</span>
                    <input type="text" id="dateTo" class="date-input" placeholder="dd/mm/yyyy" readonly>
                </div>
                <div class="calendar-container" id="calendarContainer"></div>
            </div>
        </div>
        <div class="date-picker-actions">
            <button class="btn btn-secondary" onclick="closeDatePicker()">Cancel</button>
            <button class="btn btn-primary" onclick="applyDateFilter()">Apply</button>
        </div>
    </div>
</div>

<script>
// Date Picker State
var datePickerState = {
    startDate: null,
    endDate: null,
    preset: '<%- typeof dateRange !== "undefined" ? (dateRange.preset || "all_time") : "all_time" %>',
    selecting: 'start',
    currentPage: '<%= typeof currentPage !== "undefined" ? currentPage : "dashboard" %>'
};

// Toggle date picker dropdown
function toggleDatePicker() {
    var picker = document.getElementById('datePicker');
    picker.classList.toggle('active');
    if (picker.classList.contains('active')) {
        renderCalendars();
        highlightActivePreset();
    }
}

function closeDatePicker() {
    document.getElementById('datePicker').classList.remove('active');
}

// Close picker when clicking outside
document.addEventListener('click', function(e) {
    var container = document.querySelector('.date-filter-container');
    if (container && !container.contains(e.target)) {
        closeDatePicker();
    }
});

// Initialize date picker
function initDatePicker() {
    // Set up preset clicks
    document.querySelectorAll('.preset-item').forEach(function(item) {
        item.addEventListener('click', function(e) {
            e.stopPropagation(); // Prevent picker from closing
            var preset = this.dataset.preset;
            selectPreset(preset);
        });
    });

    // Custom days input
    var customInput = document.getElementById('customDays');
    if (customInput) {
        customInput.addEventListener('change', function() {
            var days = parseInt(this.value) || 30;
            var end = new Date();
            var start = new Date();
            start.setDate(end.getDate() - days + 1);
            setDateRange(start, end, 'custom_' + days);
        });
    }

    // Date inputs
    var fromInput = document.getElementById('dateFrom');
    var toInput = document.getElementById('dateTo');

    // Date inputs are now read-only - they display the dates selected via calendar clicks

    // Initialize from URL params
    var params = new URLSearchParams(window.location.search);
    if (params.get('from') && params.get('to')) {
        datePickerState.startDate = new Date(params.get('from'));
        datePickerState.endDate = new Date(params.get('to'));
        datePickerState.preset = params.get('preset') || 'custom';
    }
    updateDateInputs();
}

// Select preset
function selectPreset(preset) {
    var today = new Date();
    today.setHours(0, 0, 0, 0);
    var start, end;

    switch(preset) {
        case 'today':
            start = end = new Date(today);
            break;
        case 'yesterday':
            start = end = new Date(today);
            start.setDate(start.getDate() - 1);
            end.setDate(end.getDate() - 1);
            break;
        case 'this_week':
            start = new Date(today);
            var dayOfWeek = start.getDay() || 7;
            start.setDate(start.getDate() - dayOfWeek + 1);
            end = new Date(today);
            break;
        case 'last_7_days':
            start = new Date(today);
            start.setDate(start.getDate() - 6);
            end = new Date(today);
            break;
        case 'last_week':
            end = new Date(today);
            var dow = end.getDay() || 7;
            end.setDate(end.getDate() - dow);
            start = new Date(end);
            start.setDate(start.getDate() - 6);
            break;
        case 'last_14_days':
            start = new Date(today);
            start.setDate(start.getDate() - 13);
            end = new Date(today);
            break;
        case 'this_month':
            start = new Date(today.getFullYear(), today.getMonth(), 1);
            end = new Date(today);
            break;
        case 'last_30_days':
            start = new Date(today);
            start.setDate(start.getDate() - 29);
            end = new Date(today);
            break;
        case 'last_month':
            start = new Date(today.getFullYear(), today.getMonth() - 1, 1);
            end = new Date(today.getFullYear(), today.getMonth(), 0);
            break;
        case 'all_time':
            start = null;
            end = null;
            break;
        default:
            start = end = null;
    }

    setDateRange(start, end, preset);
}

function setDateRange(start, end, preset) {
    datePickerState.startDate = start;
    datePickerState.endDate = end;
    datePickerState.preset = preset;
    updateDateInputs();
    highlightActivePreset();
    renderCalendars();
}

function updateDateInputs() {
    var fromInput = document.getElementById('dateFrom');
    var toInput = document.getElementById('dateTo');
    if (fromInput) {
        fromInput.value = datePickerState.startDate ? formatDateDisplay(datePickerState.startDate) : '';
    }
    if (toInput) {
        toInput.value = datePickerState.endDate ? formatDateDisplay(datePickerState.endDate) : '';
    }
}

// Format date as dd/mm/yyyy for display
function formatDateDisplay(date) {
    if (!date) return '';
    var d = new Date(date);
    var day = String(d.getDate()).padStart(2, '0');
    var month = String(d.getMonth() + 1).padStart(2, '0');
    var year = d.getFullYear();
    return day + '/' + month + '/' + year;
}

function highlightActivePreset() {
    document.querySelectorAll('.preset-item').forEach(function(item) {
        item.classList.remove('active');
        if (item.dataset.preset === datePickerState.preset) {
            item.classList.add('active');
        }
    });
}

// Apply date filter
function applyDateFilter() {
    var params = new URLSearchParams();
    if (datePickerState.startDate) {
        params.set('from', formatDateISO(datePickerState.startDate));
    }
    if (datePickerState.endDate) {
        params.set('to', formatDateISO(datePickerState.endDate));
    }
    if (datePickerState.preset) {
        params.set('preset', datePickerState.preset);
    }
    var page = '/' + datePickerState.currentPage;
    window.location.href = page + (params.toString() ? '?' + params.toString() : '');
}

// Format date as YYYY-MM-DD
function formatDateISO(date) {
    if (!date) return '';
    var d = new Date(date);
    var year = d.getFullYear();
    var month = String(d.getMonth() + 1).padStart(2, '0');
    var day = String(d.getDate()).padStart(2, '0');
    return year + '-' + month + '-' + day;
}

// Render calendars
function renderCalendars() {
    var container = document.getElementById('calendarContainer');
    if (!container) return;

    var today = new Date();
    var html = '';

    // Show current month and previous month
    for (var offset = 1; offset >= 0; offset--) {
        var month = new Date(today.getFullYear(), today.getMonth() - offset, 1);
        html += renderMonth(month);
    }

    container.innerHTML = html;

    // Add click handlers to days
    container.querySelectorAll('.dp-day:not(.empty):not(.disabled)').forEach(function(day) {
        day.addEventListener('click', function(e) {
            e.stopPropagation(); // Prevent picker from closing
            var date = new Date(this.dataset.date);
            handleDayClick(date);
        });
    });
}

function renderMonth(monthDate) {
    var monthNames = ['JAN', 'FEB', 'MAR', 'APR', 'MAY', 'JUN', 'JUL', 'AUG', 'SEP', 'OCT', 'NOV', 'DEC'];
    var weekdays = ['M', 'T', 'W', 'T', 'F', 'S', 'S'];
    var year = monthDate.getFullYear();
    var month = monthDate.getMonth();
    var firstDay = new Date(year, month, 1);
    var lastDay = new Date(year, month + 1, 0);
    var today = new Date();
    today.setHours(0, 0, 0, 0);

    var html = '<div class="dp-month">';
    html += '<div class="dp-month-title">' + monthNames[month] + ' ' + year + '</div>';
    html += '<div class="dp-weekdays">';
    weekdays.forEach(function(d) { html += '<div class="dp-weekday">' + d + '</div>'; });
    html += '</div>';
    html += '<div class="dp-days">';

    // Empty cells for days before first day of month (Monday-based week)
    var startDay = firstDay.getDay() || 7;
    for (var i = 1; i < startDay; i++) {
        html += '<div class="dp-day empty"></div>';
    }

    // Days of month
    for (var day = 1; day <= lastDay.getDate(); day++) {
        var date = new Date(year, month, day);
        date.setHours(0, 0, 0, 0);
        var dateStr = formatDateISO(date);
        var classes = ['dp-day'];

        if (date > today) {
            classes.push('disabled');
        } else {
            if (date.getTime() === today.getTime()) classes.push('today');

            // Check if in range
            if (datePickerState.startDate && datePickerState.endDate) {
                var start = new Date(datePickerState.startDate).setHours(0,0,0,0);
                var end = new Date(datePickerState.endDate).setHours(0,0,0,0);
                var current = date.getTime();

                if (current === start && current === end) {
                    classes.push('selected');
                } else if (current === start) {
                    classes.push('range-start');
                } else if (current === end) {
                    classes.push('range-end');
                } else if (current > start && current < end) {
                    classes.push('in-range');
                }
            } else if (datePickerState.startDate) {
                var startOnly = new Date(datePickerState.startDate).setHours(0,0,0,0);
                if (date.getTime() === startOnly) classes.push('selected');
            }
        }

        html += '<div class="' + classes.join(' ') + '" data-date="' + dateStr + '">' + day + '</div>';
    }

    html += '</div></div>';
    return html;
}

function handleDayClick(date) {
    if (datePickerState.selecting === 'start' || !datePickerState.startDate) {
        datePickerState.startDate = date;
        datePickerState.endDate = null;
        datePickerState.selecting = 'end';
    } else {
        if (date < datePickerState.startDate) {
            datePickerState.endDate = datePickerState.startDate;
            datePickerState.startDate = date;
        } else {
            datePickerState.endDate = date;
        }
        datePickerState.selecting = 'start';
    }
    datePickerState.preset = 'custom';
    highlightActivePreset();
    updateDateInputs();
    renderCalendars();
}

// Initialize on DOM ready
document.addEventListener('DOMContentLoaded', function() {
    initDatePicker();
});
</script>
