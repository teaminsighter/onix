<!-- Schedule Meeting Modal Template -->
<template id="scheduleMeetingModal">
    <form id="scheduleMeetingForm" onsubmit="handleScheduleMeeting(event)">
        <div class="form-group">
            <label class="form-label">Lead (optional)</label>
            <select class="form-select" name="lead_id">
                <option value="">No lead selected</option>
                <% if (typeof allLeads !== 'undefined') { allLeads.forEach(function(l) { %>
                    <option value="<%= l.id %>"><%= l.name %> - <%= l.email %></option>
                <% }); } %>
            </select>
        </div>
        <div class="form-group">
            <label class="form-label">Meeting Title</label>
            <input type="text" class="form-input" name="title" placeholder="e.g., Initial Consultation" required>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
            <div class="form-group">
                <label class="form-label">Date</label>
                <input type="date" class="form-input" name="date" required>
            </div>
            <div class="form-group">
                <label class="form-label">Time</label>
                <input type="time" class="form-input" name="time" required>
            </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
            <div class="form-group">
                <label class="form-label">Duration</label>
                <select class="form-select" name="duration">
                    <option value="15">15 minutes</option>
                    <option value="30" selected>30 minutes</option>
                    <option value="45">45 minutes</option>
                    <option value="60">1 hour</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Type</label>
                <select class="form-select" name="type">
                    <option value="call">Phone Call</option>
                    <option value="video">Video Call</option>
                    <option value="in_person">In Person</option>
                </select>
            </div>
        </div>
        <div class="form-group">
            <label class="form-label">Location / Link</label>
            <input type="text" class="form-input" name="location" placeholder="e.g., Zoom, Google Meet">
        </div>
        <div class="form-group">
            <label class="form-label">Notes</label>
            <textarea class="form-textarea" name="notes" rows="2" placeholder="Meeting agenda..."></textarea>
        </div>
        <div style="display:flex;gap:0.75rem;justify-content:flex-end;margin-top:1rem;">
            <button type="button" class="btn btn-secondary" onclick="closeModal()">Cancel</button>
            <button type="submit" class="btn btn-primary">Schedule Meeting</button>
        </div>
    </form>
</template>

<!-- Add Cost Entry Modal Template -->
<template id="addCostModal">
    <form id="addCostForm" onsubmit="handleAddCost(event)">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
            <div class="form-group">
                <label class="form-label">Source</label>
                <select class="form-select" name="source" required>
                    <option value="">Select source...</option>
                    <option value="facebook">Facebook Ads</option>
                    <option value="google">Google Ads</option>
                    <option value="linkedin">LinkedIn Ads</option>
                    <option value="other">Other</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Month</label>
                <input type="month" class="form-input" name="month" required>
            </div>
        </div>
        <div class="form-group">
            <label class="form-label">Amount ($)</label>
            <input type="number" class="form-input" name="amount" step="0.01" min="0" placeholder="0.00" required>
        </div>
        <div class="form-group">
            <label class="form-label">Campaign Name</label>
            <input type="text" class="form-input" name="campaign_name" placeholder="e.g., Q2 Lead Gen">
        </div>
        <div class="form-group">
            <label class="form-label">Leads Count</label>
            <input type="number" class="form-input" name="leads_count" min="0" value="0">
        </div>
        <div class="form-group">
            <label class="form-label">Notes</label>
            <textarea class="form-textarea" name="notes" rows="2"></textarea>
        </div>
        <div style="display:flex;gap:0.75rem;justify-content:flex-end;margin-top:1rem;">
            <button type="button" class="btn btn-secondary" onclick="closeModal()">Cancel</button>
            <button type="submit" class="btn btn-primary">Add Entry</button>
        </div>
    </form>
</template>

<!-- Add Deal Modal Template -->
<template id="addDealModal">
    <form id="addDealForm" onsubmit="handleAddDeal(event)">
        <div class="form-group">
            <label class="form-label">Lead (optional)</label>
            <select class="form-select" name="lead_id">
                <option value="">No lead selected</option>
                <% if (typeof allLeads !== 'undefined') { allLeads.forEach(function(l) { %>
                    <option value="<%= l.id %>"><%= l.name %> - <%= l.email %></option>
                <% }); } %>
            </select>
        </div>
        <div class="form-group">
            <label class="form-label">Deal Title</label>
            <input type="text" class="form-input" name="title" placeholder="e.g., Premium Package" required>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
            <div class="form-group">
                <label class="form-label">Amount ($)</label>
                <input type="number" class="form-input" name="amount" step="0.01" min="0" placeholder="0.00" required>
            </div>
            <div class="form-group">
                <label class="form-label">Source</label>
                <input type="text" class="form-input" name="source" placeholder="e.g., website">
            </div>
        </div>
        <div class="form-group">
            <label class="form-label">Notes</label>
            <textarea class="form-textarea" name="notes" rows="2"></textarea>
        </div>
        <div style="display:flex;gap:0.75rem;justify-content:flex-end;margin-top:1rem;">
            <button type="button" class="btn btn-secondary" onclick="closeModal()">Cancel</button>
            <button type="submit" class="btn btn-primary">Add Deal</button>
        </div>
    </form>
</template>

<!-- Confirmation Modal Template -->
<template id="confirmModal">
    <p id="confirmMessage" style="margin-bottom: 1.5rem; color: var(--gray-light); line-height: 1.6;"></p>
    <div style="display:flex;gap:0.75rem;justify-content:flex-end;">
        <button type="button" class="btn btn-secondary" onclick="closeModal()">Cancel</button>
        <button type="button" class="btn btn-danger" id="confirmButton" onclick="handleConfirm()">Confirm</button>
    </div>
</template>

<script>
// Old modal system (template-based) — kept for backward compat with pages that use openModal(title, templateId)
var oldModalOverlay = document.getElementById('modalOverlay');

function openOldModal(title, templateId) {
    var template = document.getElementById(templateId);
    if (!template) return;
    openModal(title, template.innerHTML);
    setTimeout(function() {
        var first = document.querySelector('#modalBody input, #modalBody select, #modalBody textarea');
        if (first) first.focus();
    }, 100);
}

// openModal is defined in layout.ejs — no override needed

function openScheduleModal() {
    openOldModal('Schedule Meeting', 'scheduleMeetingModal');
    var dateInput = document.querySelector('#scheduleMeetingForm input[name="date"]');
    if (dateInput) dateInput.value = new Date().toISOString().split('T')[0];
}

function openCostModal() {
    openOldModal('Add Cost Entry', 'addCostModal');
    var monthInput = document.querySelector('#addCostForm input[name="month"]');
    if (monthInput) monthInput.value = new Date().toISOString().slice(0, 7);
}

function openDealModal() {
    openOldModal('Add Deal', 'addDealModal');
}

function openConfirmModal(title, message, onConfirm) {
    openOldModal(title, 'confirmModal');
    document.getElementById('confirmMessage').textContent = message;
    window.pendingConfirmAction = onConfirm;
}

function handleConfirm() {
    if (window.pendingConfirmAction) {
        window.pendingConfirmAction();
        window.pendingConfirmAction = null;
    }
    closeModal();
}

// ====== Real form handlers ======

function handleScheduleMeeting(e) {
    e.preventDefault();
    var fd = new FormData(e.target);
    var date = fd.get('date');
    var time = fd.get('time');
    var duration = parseInt(fd.get('duration'));
    var start = new Date(date + 'T' + time);
    var end = new Date(start.getTime() + duration * 60000);

    fetch('/api/meetings', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            lead_id: fd.get('lead_id') || null,
            title: fd.get('title'),
            meeting_type: fd.get('type'),
            start_time: start.toISOString(),
            end_time: end.toISOString(),
            location: fd.get('location'),
            notes: fd.get('notes')
        })
    }).then(function(r) {
        if (r.ok) { closeModal(); showToast('Meeting scheduled', 'success'); window.location.reload(); }
        else r.json().then(function(d) { showToast(d.error || 'Failed', 'error'); });
    });
}

function handleAddCost(e) {
    e.preventDefault();
    var fd = new FormData(e.target);
    fetch('/api/costs', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            source: fd.get('source'),
            amount: fd.get('amount'),
            month: fd.get('month'),
            campaign_name: fd.get('campaign_name'),
            leads_count: fd.get('leads_count'),
            notes: fd.get('notes')
        })
    }).then(function(r) {
        if (r.ok) { closeModal(); showToast('Cost entry added', 'success'); window.location.reload(); }
        else r.json().then(function(d) { showToast(d.error || 'Failed', 'error'); });
    });
}

function handleAddDeal(e) {
    e.preventDefault();
    var fd = new FormData(e.target);
    fetch('/api/costs/deals', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            lead_id: fd.get('lead_id') || null,
            title: fd.get('title'),
            amount: fd.get('amount'),
            source: fd.get('source'),
            notes: fd.get('notes')
        })
    }).then(function(r) {
        if (r.ok) { closeModal(); showToast('Deal added', 'success'); window.location.reload(); }
        else r.json().then(function(d) { showToast(d.error || 'Failed', 'error'); });
    });
}

function handleEditLead(e) {
    e.preventDefault();
    var fd = new FormData(e.target);
    var id = fd.get('lead_id');
    fetch('/api/leads/' + id, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            name: fd.get('name'),
            email: fd.get('email'),
            phone: fd.get('phone'),
            priority: fd.get('priority'),
            status: fd.get('status')
        })
    }).then(function(r) {
        if (r.ok) { closeModal(); showToast('Lead updated', 'success'); window.location.reload(); }
        else showToast('Failed to update lead', 'error');
    });
}

function openEditLeadModal(lead) {
    openOldModal('Edit Lead', 'editLeadModal');
    // Template not needed for edit — use dynamic modal
    document.getElementById('modalTitle').textContent = 'Edit Lead';
    document.getElementById('modalBody').innerHTML =
        '<form onsubmit="handleEditLead(event)">' +
        '<input type="hidden" name="lead_id" value="' + lead.id + '">' +
        '<div class="form-group"><label class="form-label">Name</label><input class="form-input" name="name" value="' + escapeHtml(lead.name) + '" required></div>' +
        '<div class="form-group"><label class="form-label">Email</label><input class="form-input" name="email" type="email" value="' + escapeHtml(lead.email) + '" required></div>' +
        '<div class="form-group"><label class="form-label">Phone</label><input class="form-input" name="phone" value="' + escapeHtml(lead.phone || '') + '"></div>' +
        '<div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">' +
        '<div class="form-group"><label class="form-label">Priority</label><select class="form-select" name="priority"><option value="low"' + (lead.priority==='low'?' selected':'') + '>Low</option><option value="normal"' + (lead.priority==='normal'?' selected':'') + '>Normal</option><option value="high"' + (lead.priority==='high'?' selected':'') + '>High</option></select></div>' +
        '<div class="form-group"><label class="form-label">Status</label><select class="form-select" name="status"><option value="new"' + (lead.status==='new'?' selected':'') + '>New</option><option value="contacted"' + (lead.status==='contacted'?' selected':'') + '>Contacted</option><option value="scheduled"' + (lead.status==='scheduled'?' selected':'') + '>Scheduled</option><option value="converted"' + (lead.status==='converted'?' selected':'') + '>Converted</option><option value="lost"' + (lead.status==='lost'?' selected':'') + '>Lost</option></select></div>' +
        '</div>' +
        '<div style="display:flex;gap:0.75rem;justify-content:flex-end;margin-top:1rem;"><button type="button" class="btn btn-secondary" onclick="closeModal()">Cancel</button><button type="submit" class="btn btn-primary">Save Changes</button></div>' +
        '</form>';
}

// Close on Escape
document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeModal(); });
</script>
