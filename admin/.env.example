# =============================================
# ONIX Admin Panel — Environment Configuration
# =============================================
# Copy this file to .env: cp .env.example .env
# Then update the values below.

# Server
PORT=3001
NODE_ENV=production

# Authentication
# REQUIRED: Generate a strong secret — run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_a_64_char_hex_string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_use_a_strong_password

# Session expiry (default 24h)
SESSION_EXPIRY=24h

# Database
# Local: ./data/onix.db
# Docker/Coolify: /data/onix.db (must match volume mount)
DB_PATH=./data/onix.db

# CORS — comma-separated list of allowed origins
# Add your production domain here
CORS_ORIGIN=http://localhost:5173,https://onixmrkt.com

# Webhook secret (REQUIRED in production — secures inbound webhooks from Calendly/Formspree)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=CHANGE_ME_generate_a_64_char_hex_string

# Trust proxy (required behind Coolify/Traefik reverse proxy)
TRUST_PROXY=1

# Email notifications (optional — for lead alerts)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFICATION_EMAIL=
